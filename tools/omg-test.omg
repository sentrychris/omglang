;;;omg

import "../reference/interpreter.omg" as OMGI

# omg-test — run a list of OMG test files through the bootstrap
# tree-walk interpreter and print a pass/fail summary.
#
# Usage:  omg tools/omg-test.omg <test1.omg> [test2.omg ...]
#
# Each test file is interpreted independently.  A test passes if it runs
# to completion without raising — failures (assertions, panics, runtime
# errors) are caught and reported with the error message.
#
# Why the bootstrap interpreter?  OMG has no `system()` or `popen()`, so
# we can't shell out to `omg <file>` from inside an OMG program.  The
# tree-walk interpreter is the only way to execute another OMG file from
# within a running OMG program.  Slower than running tests directly, but
# adequate for small/fast tests and a satisfying piece of dogfooding —
# OMG running OMG that's running OMG.

if length(args) < 2 {
    panic("usage: omg tools/omg-test.omg <test.omg> [...]")
}

alloc passed := 0
alloc failed := 0
alloc fails := []
alloc i := 1
loop i < length(args) {
    alloc path := args[i]
    try {
        OMGI.run_file(path)
        emit "PASS  " + path
        passed := passed + 1
    } except err {
        emit "FAIL  " + path
        emit "      " + err
        failed := failed + 1
        fails := fails + [path]
    }
    i := i + 1
}

emit ""
emit "----"
emit passed + " passed, " + failed + " failed (" + (passed + failed) + " total)"

if failed > 0 {
    panic("test failures: " + length(fails))
}
