#!/bin/bash
# Compile a .omg source file to a standalone native ELF binary.
# No Rust runtime required.
#
# Usage: omg-build <input.omg> [<output>]
#   <output> defaults to the input path with .omg stripped.
set -e

INPUT=$1
if [ -z "$INPUT" ]; then
    echo "usage: $0 <input.omg> [<output>]" >&2
    exit 1
fi
OUTPUT=${2:-${INPUT%.omg}}

DIR=$(dirname "$(readlink -f "$0")")
WORK=$(mktemp -d)
trap "rm -rf $WORK" EXIT

"$DIR/omgc"  "$INPUT" "$WORK/a.omgb"
"$DIR/omgcc" "$WORK/a.omgb" "$WORK/a.c"
cc -O2 -w "$WORK/a.c" -o "$OUTPUT" -lm

echo "built: $OUTPUT"
