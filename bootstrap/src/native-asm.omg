;;;omg

# bootstrap/src/native-asm.omg — OMG bytecode → x86_64 Linux ELF.
#
# Reads a `.omgb` file and writes a statically-linked x86_64 Linux ELF
# that, when run, behaves like the bytecode does under the OMG VM — for
# the supported subset:
#
#   Phase 1: PUSH_STR + EMIT + HALT       — hello-world
#   Phase 2: PUSH_INT + arithmetic + EMIT — integer programs
#
# Future phases extend coverage to control flow, functions, lists,
# dicts, closures, and exceptions. See plans/06-native-asm.md.
#
# Usage:
#     omg bootstrap/src/native-asm.omg <in.omgb> <out>
#     ./<out>
#
# This is the path that lets OMG compile to a runnable binary without
# `cc` anywhere in the chain. The emitted ELF makes raw `write` and
# `exit` Linux syscalls — no libc dependency.
#
# Value tagging (matches the design sketched in plans/06-native-asm.md
# but pared down — phase 2 uses the simpler "1 bit tag" form):
#
#   LSB = 0  →  pointer to heap object (currently: string header
#               [u64 length, bytes...]; future phases add list/dict)
#   LSB = 1  →  small int, value is (n << 1) | 1, sign-extended to 64
#               bits. Phase 2 doesn't yet handle overflow into bigints;
#               every int operation assumes the inputs fit in 63 bits.

alloc VERSION    := "0.2.0"
alloc BC_VERSION := 512    # (major=0, minor=2, patch=0) packed into a u32

# === Opcode constants =====================================================
# Must match `bootstrap/src/compiler.omg`'s OP_ constants.

alloc OP_PUSH_INT       := 0
alloc OP_PUSH_STR       := 1
alloc OP_PUSH_BOOL      := 2
alloc OP_LOAD           := 5
alloc OP_STORE          := 6
alloc OP_ADD            := 7
alloc OP_SUB            := 8
alloc OP_MUL            := 9
alloc OP_DIV            := 10
alloc OP_MOD            := 11
alloc OP_EQ             := 12
alloc OP_NE             := 13
alloc OP_LT             := 14
alloc OP_LE             := 15
alloc OP_GT             := 16
alloc OP_GE             := 17
alloc OP_NOT            := 25
alloc OP_NEG            := 26
alloc OP_JUMP           := 29
alloc OP_JUMP_IF_FALSE  := 30
alloc OP_PUSH_NONE      := 35
alloc OP_EMIT           := 37
alloc OP_HALT           := 38
alloc OP_CALL           := 31
alloc OP_TCALL          := 32
alloc OP_RET            := 36
alloc OP_MAKE_FUNC      := 52
alloc OP_STORE_LOCAL    := 53
alloc OP_BUILD_LIST     := 3
alloc OP_BUILD_DICT     := 4
alloc OP_INDEX          := 27
alloc OP_SLICE          := 28
alloc OP_BUILTIN        := 33
alloc OP_POP            := 34
alloc OP_STORE_INDEX    := 39
alloc OP_CALL_VALUE     := 43
alloc OP_SETUP_EXCEPT   := 44
alloc OP_POP_BLOCK      := 45
alloc OP_RAISE          := 46
alloc OP_PUSH_FLOAT     := 54

# === ELF / x86_64 layout ==================================================
# We map the whole file as a single PT_LOAD segment at virtual address
# 0x400000 with read+exec permissions. The ELF header itself sits at the
# start of that segment — conventional for tiny binaries; the kernel
# reads it then leaves it as part of the executable mapping, never
# executed (entry points past it). The runtime blob follows the
# headers, then user code (which is the entry point), then string
# headers as a small data area.

alloc ELF_BASE        := 4194304    # 0x400000
alloc ELF_HEADER_SIZE := 64
alloc PHDR_SIZE       := 56
alloc HEADERS_SIZE    := 120        # ELF_HEADER_SIZE + PHDR_SIZE

# Operand-stack region: a zero-filled chunk of memory at the high end
# of the mapped segment, reserved via `p_memsz - p_filesz` so it doesn't
# bloat the on-disk binary. r15 holds the operand-stack pointer (top
# of stack, grows downward). Separated from the native call stack so
# function calls can use native call/ret without colliding with our
# value discipline. 64 KB is overkill for everything we currently do.
alloc OPERAND_STACK_SIZE := 65536

# Heap region: a zero-filled chunk before the operand stack, where
# runtime-allocated objects (lists, dicts, dynamic strings) live. r13
# holds the bump-allocator pointer; allocation grows it upward. 1 MB
# is enough for everything in the corpus; phase 10 will add a GC so
# this can be smaller.
#
# The first 8 bytes of the heap region are reserved for the
# `except_top` slot — a single 8-byte memory location holding the
# current top of the exception handler stack. r13 starts at heap_base
# + 8 so user allocations don't overwrite it.
alloc HEAP_SIZE := 1048576

# Exception-handler stack region: grows upward from a base just past
# the operand stack. Each handler record is 40 bytes:
#   [0]:  handler_addr (absolute virtual address of the except block)
#   [8]:  saved r15
#   [16]: saved r14
#   [24]: saved r12
#   [32]: saved rsp
# At RAISE, we walk back the top record and restore (r15, r14, r12,
# rsp), then jump to handler_addr. 8 KB = 200+ nested try blocks.
alloc EXCEPT_STACK_SIZE   := 8192
alloc HANDLER_RECORD_SIZE := 40

# Heap object layout. Every heap-allocated object starts with a u64
# type tag so the EMIT dispatcher (and future operations like INDEX)
# can route by shape:
#   HEAP_T_STRING  = 0   →  [type=0, length, bytes...]
#   HEAP_T_LIST    = 1   →  [type=1, length, capacity, element_0...]
#   (more in phase 5b)
alloc HEAP_T_STRING  := 0
alloc HEAP_T_LIST    := 1
alloc HEAP_T_DICT    := 2
alloc HEAP_T_CLOSURE := 3
# 4 = HEAP_T_ENV (set in gen_make_func; not externally addressed)
alloc HEAP_T_FLOAT   := 5

# Sentinel tag values for bool / none. All have LSB=0 (so they look
# like pointers to the dispatcher's first test) and bits 1-2 set in a
# way that no real heap pointer can match (since heap addresses live
# at >= 0x400000 and the sentinels are tiny). The dispatcher checks
# these by direct equality after ruling out ints.
alloc TAG_FALSE := 2
alloc TAG_TRUE  := 4
alloc TAG_NONE  := 6

# === Bytecode reading =====================================================

proc read_u32_at(bytes, i) {
    alloc v := bytes[i] | (bytes[i+1] << 8) | (bytes[i+2] << 16) | (bytes[i+3] << 24)
    return [v, i + 4]
}

proc read_i64_at(bytes, i) {
    alloc lo_pair := read_u32_at(bytes, i)
    alloc hi_pair := read_u32_at(bytes, i + 4)
    alloc v := (hi_pair[0] << 32) | lo_pair[0]
    return [v, i + 8]
}

proc read_str_at(bytes, i) {
    alloc len_pair := read_u32_at(bytes, i)
    alloc len := len_pair[0]
    alloc start := len_pair[1]
    alloc s := bytes_to_string(bytes[start:start + len])
    return [s, start + len]
}

proc parse_bytecode(bytes) {
    alloc n := length(bytes)
    if n < 8 { panic("native-asm: bytecode too short") }
    alloc bad_magic := bytes[0] != ascii("O") or bytes[1] != ascii("M") or bytes[2] != ascii("G") or bytes[3] != ascii("B")
    if bad_magic {
        panic("native-asm: bad magic in header")
    }
    alloc cursor := 4
    alloc ver_pair := read_u32_at(bytes, cursor)
    cursor := ver_pair[1]
    if ver_pair[0] != BC_VERSION {
        panic("native-asm: unsupported bytecode version " + ver_pair[0])
    }
    # Source-file table — skip.
    alloc sfc_pair := read_u32_at(bytes, cursor)
    cursor := sfc_pair[1]
    alloc si := 0
    loop si < sfc_pair[0] {
        alloc sp := read_str_at(bytes, cursor)
        cursor := sp[1]
        si := si + 1
    }
    # Function table: each entry maps a mangled name to its parameter
    # list and bytecode entry index. Phase 4 codegen lowers Call("name")
    # into a native rel32 jump into the function's machine entry; the
    # bytecode index is how we slice each function's body out of the
    # single concatenated code stream below.
    alloc fc_pair := read_u32_at(bytes, cursor)
    alloc func_count := fc_pair[0]
    cursor := fc_pair[1]
    alloc funcs := []
    alloc f := 0
    loop f < func_count {
        alloc name_pair := read_str_at(bytes, cursor)
        alloc fname := name_pair[0]
        cursor := name_pair[1]
        alloc pc_pair := read_u32_at(bytes, cursor)
        alloc param_count := pc_pair[0]
        cursor := pc_pair[1]
        alloc params := []
        alloc p := 0
        loop p < param_count {
            alloc p_pair := read_str_at(bytes, cursor)
            params := params + [p_pair[0]]
            cursor := p_pair[1]
            p := p + 1
        }
        alloc addr_pair := read_u32_at(bytes, cursor)
        cursor := addr_pair[1]
        alloc sfi_pair := read_u32_at(bytes, cursor)
        cursor := sfi_pair[1]
        funcs := funcs + [[fname, params, addr_pair[0]]]
        f := f + 1
    }
    # Code stream.
    alloc cl_pair := read_u32_at(bytes, cursor)
    alloc code_len := cl_pair[0]
    cursor := cl_pair[1]
    alloc code := []
    alloc k := 0
    loop k < code_len {
        alloc op := bytes[cursor]
        cursor := cursor + 1
        if op == OP_PUSH_INT {
            alloc r := read_i64_at(bytes, cursor)
            code := code + [["PUSH_INT", r[0]]]
            cursor := r[1]
        } else { if op == OP_PUSH_FLOAT {
            # Float bytecode carries the IEEE-754 bit pattern as 8 bytes.
            alloc rf := read_i64_at(bytes, cursor)
            code := code + [["PUSH_FLOAT", rf[0]]]
            cursor := rf[1]
        } else { if op == OP_PUSH_STR {
            alloc rs := read_str_at(bytes, cursor)
            code := code + [["PUSH_STR", rs[0]]]
            cursor := rs[1]
        } else { if op == OP_PUSH_BOOL {
            alloc bv := bytes[cursor] != 0
            code := code + [["PUSH_BOOL", bv]]
            cursor := cursor + 1
        } else { if op == OP_PUSH_NONE {
            code := code + [["PUSH_NONE", false]]
        } else { if op == OP_JUMP {
            alloc rj := read_u32_at(bytes, cursor)
            code := code + [["JUMP", rj[0]]]
            cursor := rj[1]
        } else { if op == OP_JUMP_IF_FALSE {
            alloc rjf := read_u32_at(bytes, cursor)
            code := code + [["JUMP_IF_FALSE", rjf[0]]]
            cursor := rjf[1]
        } else { if op == OP_LOAD {
            alloc rl := read_str_at(bytes, cursor)
            code := code + [["LOAD", rl[0]]]
            cursor := rl[1]
        } else { if op == OP_STORE {
            alloc rst := read_str_at(bytes, cursor)
            code := code + [["STORE", rst[0]]]
            cursor := rst[1]
        } else { if op == OP_STORE_LOCAL {
            alloc rsl := read_str_at(bytes, cursor)
            code := code + [["STORE_LOCAL", rsl[0]]]
            cursor := rsl[1]
        } else { if op == OP_CALL {
            alloc rc := read_str_at(bytes, cursor)
            code := code + [["CALL", rc[0]]]
            cursor := rc[1]
        } else { if op == OP_TCALL {
            alloc rtc := read_str_at(bytes, cursor)
            code := code + [["TCALL", rtc[0]]]
            cursor := rtc[1]
        } else { if op == OP_MAKE_FUNC {
            alloc rmf := read_str_at(bytes, cursor)
            code := code + [["MAKE_FUNC", rmf[0]]]
            cursor := rmf[1]
        } else { if op == OP_RET {
            code := code + [["RET", false]]
        } else { if op == OP_BUILD_LIST {
            alloc rbl := read_u32_at(bytes, cursor)
            code := code + [["BUILD_LIST", rbl[0]]]
            cursor := rbl[1]
        } else { if op == OP_BUILD_DICT {
            alloc rbd := read_u32_at(bytes, cursor)
            code := code + [["BUILD_DICT", rbd[0]]]
            cursor := rbd[1]
        } else { if op == OP_CALL_VALUE {
            alloc rcv := read_u32_at(bytes, cursor)
            code := code + [["CALL_VALUE", rcv[0]]]
            cursor := rcv[1]
        } else { if op == OP_SETUP_EXCEPT {
            alloc rse := read_u32_at(bytes, cursor)
            code := code + [["SETUP_EXCEPT", rse[0]]]
            cursor := rse[1]
        } else { if op == OP_RAISE {
            alloc rrk := bytes[cursor]
            code := code + [["RAISE", rrk]]
            cursor := cursor + 1
        } else { if op == OP_BUILTIN {
            alloc nm := read_str_at(bytes, cursor)
            alloc ac := read_u32_at(bytes, nm[1])
            code := code + [["BUILTIN", [nm[0], ac[0]]]]
            cursor := ac[1]
        } else {
            if op == OP_ADD  { code := code + [["ADD",  false]] } else {
            if op == OP_SUB  { code := code + [["SUB",  false]] } else {
            if op == OP_MUL  { code := code + [["MUL",  false]] } else {
            if op == OP_DIV  { code := code + [["DIV",  false]] } else {
            if op == OP_MOD  { code := code + [["MOD",  false]] } else {
            if op == OP_NEG  { code := code + [["NEG",  false]] } else {
            if op == OP_NOT  { code := code + [["NOT",  false]] } else {
            if op == OP_EQ   { code := code + [["EQ",   false]] } else {
            if op == OP_NE   { code := code + [["NE",   false]] } else {
            if op == OP_LT   { code := code + [["LT",   false]] } else {
            if op == OP_LE   { code := code + [["LE",   false]] } else {
            if op == OP_GT   { code := code + [["GT",   false]] } else {
            if op == OP_GE          { code := code + [["GE",          false]] } else {
            if op == OP_INDEX       { code := code + [["INDEX",       false]] } else {
            if op == OP_SLICE       { code := code + [["SLICE",       false]] } else {
            if op == OP_STORE_INDEX { code := code + [["STORE_INDEX", false]] } else {
            if op == OP_POP         { code := code + [["POP",         false]] } else {
            if op == OP_POP_BLOCK   { code := code + [["POP_BLOCK",   false]] } else {
            if op == OP_EMIT        { code := code + [["EMIT",        false]] } else {
            if op == OP_HALT        { code := code + [["HALT",        false]] } else {
                panic("native-asm: opcode " + op + " not yet supported")
            }}}}}}}}}}}}}}}}}}}}
        }}}}}}}}}}}}}}}}}}}}
        k := k + 1
    }
    return [code, funcs]
}

# === Output byte buffer ===================================================
# Same shape as compiler.omg's wb_buf; local to this module.

alloc ob_buf := []
alloc ob_top := 0

proc ob_reset() {
    ob_buf := list_repeat(0, 4096)
    ob_top := 0
}

proc ob_grow_if_needed() {
    if ob_top < length(ob_buf) { return false }
    alloc new_cap := length(ob_buf) * 2
    alloc fresh := list_repeat(0, new_cap)
    alloc i := 0
    loop i < ob_top {
        fresh[i] := ob_buf[i]
        i := i + 1
    }
    ob_buf := fresh
}

proc ob_byte(b) {
    ob_grow_if_needed()
    ob_buf[ob_top] := b & 255
    ob_top := ob_top + 1
}

proc ob_u32(n) {
    ob_byte(n & 255)
    ob_byte((n >> 8) & 255)
    ob_byte((n >> 16) & 255)
    ob_byte((n >> 24) & 255)
}

proc ob_u64(n) {
    alloc x := n
    alloc i := 0
    loop i < 8 {
        ob_byte(x & 255)
        x := x >> 8
        i := i + 1
    }
}

proc ob_string_bytes(s) {
    alloc i := 0
    alloc n := length(s)
    loop i < n {
        ob_byte(ascii(s[i]))
        i := i + 1
    }
}

# Emit a fixed sequence of bytes from a list. Used by the encoders to
# spell out each x86_64 instruction in one statement per opcode.
proc ob_bytes(bs) {
    alloc i := 0
    alloc n := length(bs)
    loop i < n {
        ob_byte(bs[i])
        i := i + 1
    }
}

proc ob_patch_u32(offset, n) {
    ob_buf[offset]     := n & 255
    ob_buf[offset + 1] := (n >> 8) & 255
    ob_buf[offset + 2] := (n >> 16) & 255
    ob_buf[offset + 3] := (n >> 24) & 255
}

proc ob_patch_u8(offset, n) {
    ob_buf[offset] := n & 255
}

# === x86_64 instruction encoders ==========================================
# Register indices match the x86_64 encoding (low 8 only):
#   0=rax 1=rcx 2=rdx 3=rbx 4=rsp 5=rbp 6=rsi 7=rdi

alloc REG_RAX := 0
alloc REG_RCX := 1
alloc REG_RDX := 2
alloc REG_RBX := 3
alloc REG_RSP := 4
alloc REG_RBP := 5
alloc REG_RSI := 6
alloc REG_RDI := 7

# `mov r64, imm32` — sign-extended. 7 bytes. For values < 2^31.
proc x_mov_imm32(reg, imm) {
    ob_byte(72)
    ob_byte(199)
    ob_byte(192 + reg)
    ob_u32(imm)
}

# `mov r64, imm64` — full 64-bit immediate. 10 bytes. For tagged values
# that don't fit in a sign-extended imm32 (i.e. anything outside the
# 31-bit signed range once shifted).
proc x_mov_imm64(reg, imm) {
    ob_byte(72)
    ob_byte(184 + reg)
    ob_u64(imm)
}

# Operand-stack push for low-8 regs. Two native instructions:
#   sub r15, 8                # 4 bytes — make room
#   mov [r15], <reg>          # 3 bytes — store
# Total 7 bytes. The grow-down convention matches the conventional
# stack discipline and means the first push lands at the highest
# valid address in the reserved region.
proc x_push_reg(reg) {
    # sub r15, 8 — 49 83 ef 08
    ob_bytes([73, 131, 239, 8])
    # mov [r15], reg — 49 89 <ModR/M (mod=00, reg=<reg>, rm=111(r15))>
    ob_bytes([73, 137, (reg << 3) | 7])
}

# Operand-stack pop for low-8 regs. Two native instructions:
#   mov <reg>, [r15]          # 3 bytes — load
#   add r15, 8                # 4 bytes — release
# Total 7 bytes.
proc x_pop_reg(reg) {
    # mov reg, [r15] — 49 8b <ModR/M>
    ob_bytes([73, 139, (reg << 3) | 7])
    # add r15, 8 — 49 83 c7 08
    ob_bytes([73, 131, 199, 8])
}

# Load r15 with a 64-bit immediate. Used by the entry-point prologue
# to initialise the operand-stack pointer. Returns the patch site for
# the imm64 (the absolute virtual address of the operand-stack top
# isn't known until layout is finalised).
proc x_mov_r15_imm64_patchable() {
    # REX.W + REX.B + opcode B8+7 (r15) — 49 bf <imm64>
    ob_bytes([73, 191])
    alloc site := ob_top
    ob_u64(0)
    return site
}

# Same for r13 (used as the bump-allocator pointer). Encoding:
# REX.W + REX.B + opcode B8+5 (r13) — 49 bd <imm64>
proc x_mov_r13_imm64_patchable() {
    ob_bytes([73, 189])
    alloc site := ob_top
    ob_u64(0)
    return site
}

# `ret` — 1 byte.
proc x_ret() { ob_byte(195) }

# `syscall` — 2 bytes.
proc x_syscall() {
    ob_byte(15)
    ob_byte(5)
}

# Common simple ops.
proc x_xor_rdi_rdi() { ob_bytes([72, 49, 255]) }
proc x_xor_rdx_rdx() { ob_bytes([72, 49, 210]) }

# `add rax, rbx` — 3 bytes.
proc x_add_rax_rbx() { ob_bytes([72, 1, 216]) }

# `sub rax, rbx` — 3 bytes.
proc x_sub_rax_rbx() { ob_bytes([72, 41, 216]) }

# `sub rax, imm8` (sign-extended) — 4 bytes.
proc x_sub_rax_imm8(n) { ob_bytes([72, 131, 232, n & 255]) }

# `sub rbx, imm8` — 4 bytes.
proc x_sub_rbx_imm8(n) { ob_bytes([72, 131, 235, n & 255]) }

# `or rax, imm8` (sign-extended) — 4 bytes.
proc x_or_rax_imm8(n) { ob_bytes([72, 131, 200, n & 255]) }

# `neg rax` — 3 bytes.
proc x_neg_rax() { ob_bytes([72, 247, 216]) }

# `imul rax, rbx` — 4 bytes.
proc x_imul_rax_rbx() { ob_bytes([72, 15, 175, 195]) }

# `idiv rbx` — 3 bytes. rdx:rax / rbx → rax = quotient, rdx = remainder.
proc x_idiv_rbx() { ob_bytes([72, 247, 251]) }

# `cqo` — 2 bytes. Sign-extend rax into rdx.
proc x_cqo() { ob_bytes([72, 153]) }

# `sar rax, 1` (arithmetic right shift) — 3 bytes.
proc x_sar_rax_1() { ob_bytes([72, 209, 248]) }

# `sar rbx, 1` — 3 bytes.
proc x_sar_rbx_1() { ob_bytes([72, 209, 251]) }

# `sal rax, 1` (= shl) — 3 bytes.
proc x_sal_rax_1() { ob_bytes([72, 209, 224]) }

# `mov rdx, rax` — 3 bytes.
proc x_mov_rdx_rax() { ob_bytes([72, 137, 194]) }

# `mov rax, rdx` — 3 bytes. (Used by MOD to retrieve the remainder
# out of the idiv result, which leaves the remainder in rdx.)
proc x_mov_rax_rdx() { ob_bytes([72, 137, 208]) }

# `mov rcx, rax` — 3 bytes.
proc x_mov_rcx_rax() { ob_bytes([72, 137, 193]) }

# `and rcx, rbx` — 3 bytes.
proc x_and_rcx_rbx() { ob_bytes([72, 33, 217]) }

# `test cl, 1` — 3 bytes.
proc x_test_cl_1() { ob_bytes([246, 193, 1]) }

# `cmp rax, rbx` — 3 bytes.
proc x_cmp_rax_rbx() { ob_bytes([72, 57, 216]) }

# `cmp rax, imm8` (sign-extended) — 4 bytes. Use for comparisons
# against small constants like the bool/none sentinels.
proc x_cmp_rax_imm8(n) { ob_bytes([72, 131, 248, n & 255]) }

# `sub rcx, rax` — 3 bytes. Used by NOT to compute 6 - rax.
proc x_sub_rcx_rax() { ob_bytes([72, 41, 193]) }

# Conditional moves between rax (destination) and rcx (source). Used
# by comparisons: assume "true" in rax, then conditionally swap to
# "false" in rcx when the inverse condition holds. The 4-byte
# encodings all share REX.W + 0f + <cc opcode> + ModR/M c1.
proc x_cmove_rax_rcx()  { ob_bytes([72, 15, 68, 193]) }   # eq
proc x_cmovne_rax_rcx() { ob_bytes([72, 15, 69, 193]) }   # ne
proc x_cmovl_rax_rcx()  { ob_bytes([72, 15, 76, 193]) }   # signed <
proc x_cmovge_rax_rcx() { ob_bytes([72, 15, 77, 193]) }   # signed >=
proc x_cmovle_rax_rcx() { ob_bytes([72, 15, 78, 193]) }   # signed <=
proc x_cmovg_rax_rcx()  { ob_bytes([72, 15, 79, 193]) }   # signed >

# Unconditional `jmp rel32` — 5 bytes. Returns the file offset of the
# rel32 imm so the caller can patch it once the target is known.
proc x_jmp_rel32_patchable() {
    ob_byte(233)
    alloc site := ob_top
    ob_u32(0)
    return site
}

# Conditional `je rel32` — 6 bytes (0f 84 <rel32>). Returns the patch
# site (offset of rel32 imm). Same calling pattern as
# x_jmp_rel32_patchable.
proc x_je_rel32_patchable() {
    ob_bytes([15, 132])
    alloc site := ob_top
    ob_u32(0)
    return site
}

# Patch a 5-byte `jmp rel32` or 6-byte `jcc rel32`. The rel32 is
# relative to the byte AFTER the rel32 itself (i.e. site + 4).
proc patch_rel32(site, target_offset) {
    alloc disp := target_offset - (site + 4)
    ob_patch_u32(site, disp & 4294967295)
}

# Read/write a global slot. Globals live in a fixed memory region at
# the end of the ELF (see emit_globals_area). Each global occupies 8
# bytes; the codegen knows each name's slot index, so the address is
# `globals_base_vaddr + slot * 8`. The mov encodings here use
# `[rip + disp32]` addressing so the binary is position-independent
# enough for our needs — but since we know absolute virtual addresses
# at emit time, we use `mov rax, [imm32]` (absolute moffs form, 5
# bytes) and `mov rdx, [imm32]` etc. via `mov r64, [rip+disp32]`.
# Simpler: load the address into a register first, then dereference.

# `mov rax, [rcx]` — 3 bytes. Used after loading a global's address.
proc x_mov_rax_mem_rcx() { ob_bytes([72, 139, 1]) }

# `mov [rcx], rax` — 3 bytes.
proc x_mov_mem_rcx_rax() { ob_bytes([72, 137, 1]) }

# `call rel32` — 5 bytes. Returns the file offset of the rel32 imm so
# the caller can patch it once the target address is known.
proc x_call_rel32_patchable() {
    ob_byte(232)
    alloc site := ob_top
    ob_u32(0)
    return site
}

# Patch a 5-byte `call rel32` at site so it targets `target_offset` in
# the file. The displacement is computed relative to the byte after
# the rel32 (i.e. site + 4).
proc patch_call_rel32(site, target_offset) {
    alloc disp := target_offset - (site + 4)
    # Mask to 32 bits since OMG ints are 64-bit signed and ob_patch_u32
    # only reads the low 4 bytes.
    ob_patch_u32(site, disp & 4294967295)
}

# === Runtime blob =========================================================
# The runtime blob lives at file offset HEADERS_SIZE (120). It contains
# three small assembly helpers:
#
#   rt_emit_dispatch — entry for the EMIT opcode. Takes a tagged value
#                      in rax and jumps to either rt_emit_int (LSB=1)
#                      or rt_emit_str (LSB=0).
#   rt_emit_int      — converts the int in rax (after untagging) to
#                      decimal ASCII, then writes it to stdout with a
#                      trailing newline.
#   rt_emit_str      — writes a [u64 length, bytes...] structure
#                      pointed to by rax to stdout, then a newline.
#
# Each helper is emitted into ob_buf; this proc returns a record of
# their entry-point file offsets so user code's CALL sites can be
# patched to the right targets.

# Set up r9 and r8 to the end of a stack buffer ready for digit
# emission. r9 = one past end; r8 = current write pointer. Phase 5c
# stripped the trailing newline — the dispatcher's print wrapper now
# writes it once at the end of the whole value, so individual element
# renders inside lists/dicts don't insert newlines mid-output.
# Assumes the caller has done `sub rsp, 64`.
proc emit_rt_emit_int_setup() {
    # lea r9, [rsp + 64]  — 4c 8d 4c 24 40 (one past the last byte)
    ob_bytes([76, 141, 76, 36, 64])
    # mov r8, r9          — 4d 89 c8
    ob_bytes([77, 137, 200])
}

# Emit one runtime helper and return its offset within the blob.
proc emit_rt_emit_int() {
    alloc entry := ob_top
    # sub rsp, 64 — 48 83 ec 40 (we need 64 bytes of scratch; the rsp
    # red zone is only 128 bytes and we'd rather not rely on it across
    # the syscall).
    ob_bytes([72, 131, 236, 64])
    # sar rax, 1 — untag (sign-extends)
    x_sar_rax_1()
    emit_rt_emit_int_setup()
    # mov bl, 0 — b3 00 (bl = sign flag)
    ob_bytes([179, 0])
    # test rax, rax — 48 85 c0
    ob_bytes([72, 133, 192])
    # jns +5 (skip the negate+flag-set) — 79 05
    ob_bytes([121, 5])
    # neg rax
    x_neg_rax()
    # mov bl, 1 — b3 01
    ob_bytes([179, 1])
    # === digit_loop: ===
    alloc loop_start := ob_top
    # mov rcx, 10
    x_mov_imm32(REG_RCX, 10)
    # xor rdx, rdx
    x_xor_rdx_rdx()
    # div rcx — 48 f7 f1 (unsigned division; rax is non-negative here)
    ob_bytes([72, 247, 241])
    # add dl, '0' — 80 c2 30
    ob_bytes([128, 194, 48])
    # dec r8 — 49 ff c8
    ob_bytes([73, 255, 200])
    # mov [r8], dl — 41 88 10
    ob_bytes([65, 136, 16])
    # test rax, rax — 48 85 c0
    ob_bytes([72, 133, 192])
    # jnz <loop_start> — 75 <rel8 backward>
    ob_byte(117)
    alloc back := loop_start - (ob_top + 1)
    ob_byte(back & 255)
    # test bl, bl — 84 db
    ob_bytes([132, 219])
    # jz +7 (skip the prepend-sign block: dec r8 = 3 bytes + mov byte
    # [r8], '-' = 4 bytes, total 7) — 74 07
    ob_bytes([116, 7])
    # dec r8 — 49 ff c8
    ob_bytes([73, 255, 200])
    # mov byte [r8], '-' — 41 c6 00 2d
    ob_bytes([65, 198, 0, 45])
    # === write to stdout ===
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    # mov rsi, r8 — 4c 89 c6
    ob_bytes([76, 137, 198])
    # mov rdx, r9 — 4c 89 ca
    ob_bytes([76, 137, 202])
    # sub rdx, r8 — 4c 29 c2 (write length = r9 - r8, no newline)
    ob_bytes([76, 41, 194])
    x_syscall()
    # add rsp, 64 — 48 83 c4 40
    ob_bytes([72, 131, 196, 64])
    x_ret()
    return entry
}

# Write the [u64 length, bytes...] structure pointed to by rax, then a
# trailing newline byte (allocated on the native stack briefly).
proc emit_rt_emit_str() {
    alloc entry := ob_top
    # Heap-object layout for strings: [type=0:u64][length:u64][bytes...].
    # We trust the type at [rax] is HEAP_T_STRING here — the dispatcher
    # guards that by checking the tag before jumping to us. No trailing
    # newline (phase 5c) — the print wrapper adds it once at the end.
    # mov rdx, [rax + 8] — 48 8b 50 08
    ob_bytes([72, 139, 80, 8])
    # lea rsi, [rax + 16] — 48 8d 70 10
    ob_bytes([72, 141, 112, 16])
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_syscall()
    x_ret()
    return entry
}

# Branch on the LSB of rax and jump to the right helper. Returns its
# own entry offset; takes the two helper offsets so we can compute
# proper rel32 displacements at emit time.
# Bump allocator. Maintains a heap pointer in r13; allocations grow
# upward. No deallocation — heap fills until OOM (the kernel will SIGV
# on memory access past p_memsz). Phase 10 replaces this with a GC.
#
# Input:  rax = bytes to allocate
# Output: rax = pointer to the allocation
# Clobbers: rcx
proc emit_rt_alloc() {
    alloc entry := ob_top
    # mov rcx, rax — 48 89 c1
    ob_bytes([72, 137, 193])
    # mov rax, r13 — 4c 89 e8
    ob_bytes([76, 137, 232])
    # add r13, rcx — 49 01 cd
    ob_bytes([73, 1, 205])
    x_ret()
    return entry
}

# Slice a container into a new heap-allocated container of the same
# type. Dispatches by [rax]'s type tag: string → byte-wise rep movsb,
# list → quadword rep movsq. Phase 5d trusts the bytecode — invalid
# indices (negative, > length) produce undefined output rather than
# panicking. Will tighten in phase 8.
#
# Input:  rax = container pointer
#         rbx = tagged start index
#         rcx = tagged end index (exclusive)
# Output: rax = new container pointer
# Clobbers: rcx, rdx, rsi, rdi, r8
proc emit_rt_slice(alloc_off) {
    alloc entry := ob_top
    # Untag start/end.
    x_sar_rbx_1()
    # sar rcx, 1 — 48 d1 f9
    ob_bytes([72, 209, 249])
    # rdx = end - start (new length); leave rcx unused going forward.
    # mov rdx, rcx — 48 89 ca
    ob_bytes([72, 137, 202])
    # sub rdx, rbx — 48 29 da
    ob_bytes([72, 41, 218])
    # Test type at [rax].
    # mov rcx, [rax] — 48 8b 08
    ob_bytes([72, 139, 8])
    # cmp rcx, 1 — 48 83 f9 01
    ob_bytes([72, 131, 249, 1])
    # je .list_path (rel32 — easier than rel8 since the string path is big)
    ob_bytes([15, 132])
    alloc je_list_site := ob_top
    ob_u32(0)
    # === STRING PATH ===
    # Save src ptr (rax), start (rbx), length (rdx).
    ob_byte(80)                              # push rax (src)
    ob_byte(83)                              # push rbx (start)
    ob_byte(82)                              # push rdx (length)
    # Allocate 16 + length, padded to 8.
    # mov rax, rdx — 48 89 d0
    ob_bytes([72, 137, 208])
    # add rax, 23 — 48 83 c0 17
    ob_bytes([72, 131, 192, 23])
    # and rax, -8 — 48 83 e0 f8
    ob_bytes([72, 131, 224, 248])
    alloc s_alloc_s := x_call_rel32_patchable()
    patch_call_rel32(s_alloc_s, alloc_off)
    # rax = new ptr. Pop length, start, src.
    ob_byte(90)                              # pop rdx (length)
    ob_byte(91)                              # pop rbx (start)
    ob_byte(89)                              # pop rcx (src)
    # Write header [type=0, length].
    # mov qword [rax], 0 — 48 c7 00 00 00 00 00
    ob_bytes([72, 199, 0, 0, 0, 0, 0])
    # mov [rax + 8], rdx — 48 89 50 08
    ob_bytes([72, 137, 80, 8])
    # rep movsb setup:
    #   rsi = src + 16 + start
    #   rdi = new + 16
    #   rcx = length
    # mov rsi, rcx — 48 89 ce (src ptr was popped into rcx above)
    ob_bytes([72, 137, 206])
    # add rsi, 16 — 48 83 c6 10
    ob_bytes([72, 131, 198, 16])
    # add rsi, rbx — 48 01 de
    ob_bytes([72, 1, 222])
    # lea rdi, [rax + 16] — 48 8d 78 10
    ob_bytes([72, 141, 120, 16])
    # mov rcx, rdx — 48 89 d1
    ob_bytes([72, 137, 209])
    # rep movsb — f3 a4
    ob_bytes([243, 164])
    x_ret()
    # === LIST PATH ===
    alloc list_off := ob_top
    patch_rel32(je_list_site, list_off)
    # Save src ptr, start, length on native stack.
    ob_byte(80)                              # push rax (src)
    ob_byte(83)                              # push rbx (start)
    ob_byte(82)                              # push rdx (length)
    # Allocate 24 + length*8 (list header + elements).
    # mov rax, rdx — 48 89 d0
    ob_bytes([72, 137, 208])
    # shl rax, 3 — 48 c1 e0 03
    ob_bytes([72, 193, 224, 3])
    # add rax, 24 — 48 83 c0 18
    ob_bytes([72, 131, 192, 24])
    alloc l_alloc_s := x_call_rel32_patchable()
    patch_call_rel32(l_alloc_s, alloc_off)
    ob_byte(90)                              # pop rdx (length)
    ob_byte(91)                              # pop rbx (start)
    ob_byte(89)                              # pop rcx (src)
    # Write header [type=1, length, capacity=length].
    # mov qword [rax], 1 — 48 c7 00 01 00 00 00
    ob_bytes([72, 199, 0, 1, 0, 0, 0])
    # mov [rax + 8], rdx — 48 89 50 08
    ob_bytes([72, 137, 80, 8])
    # mov [rax + 16], rdx — 48 89 50 10
    ob_bytes([72, 137, 80, 16])
    # rep movsq setup:
    #   rsi = src + 24 + start*8         (use lea with SIB)
    #   rdi = new + 24
    #   rcx = length
    # lea rsi, [rcx + 24] — 48 8d 71 18 (we'll then add start*8 separately)
    # Easier: lea rsi, [rcx + rbx*8 + 24]
    # 48 8d 74 d9 18:
    #   48 REX.W
    #   8d lea
    #   ModR/M: mod=01 (disp8), reg=rsi(110), rm=100 (SIB) → 0x74
    #   SIB: scale=11(8), index=rbx(011), base=rcx(001) → 0xd9
    #   disp8 = 24
    ob_bytes([72, 141, 116, 217, 24])
    # lea rdi, [rax + 24] — 48 8d 78 18
    ob_bytes([72, 141, 120, 24])
    # mov rcx, rdx — 48 89 d1
    ob_bytes([72, 137, 209])
    # rep movsq — f3 48 a5
    ob_bytes([243, 72, 165])
    x_ret()
    return entry
}

# INDEX dispatcher. Routes by container type:
#   type=1 (list)  → inline [container + 24 + index*8]
#   type=2 (dict)  → tail call to rt_dict_get
#
# Input:  rax = container, rbx = key (tagged int for list, ptr for dict)
# Output: rax = value
proc emit_rt_index(dict_get_off) {
    alloc entry := ob_top
    # mov rcx, [rax]
    ob_bytes([72, 139, 8])
    # cmp rcx, 1 — 48 83 f9 01
    ob_bytes([72, 131, 249, 1])
    # je .list (rel8 placeholder)
    ob_byte(116)
    alloc je_list := ob_top
    ob_byte(0)
    # cmp rcx, 2 — 48 83 f9 02
    ob_bytes([72, 131, 249, 2])
    # je .dict (rel8)
    ob_byte(116)
    alloc je_dict := ob_top
    ob_byte(0)
    # panic (exit 3)
    x_mov_imm32(REG_RAX, 60)
    x_mov_imm32(REG_RDI, 3)
    x_syscall()
    # .list — untag index, load element, return
    ob_patch_u8(je_list, ob_top - (je_list + 1))
    # sar rbx, 1
    ob_bytes([72, 209, 251])
    # mov rax, [rax + 24 + rbx*8]
    # ModR/M: mod=01, reg=000 (rax), rm=100 (SIB) → 0x44
    # SIB:    scale=11 (×8), index=011 (rbx), base=000 (rax) → 11_011_000 = 0xd8
    # disp8=24
    ob_bytes([72, 139, 68, 216, 24])
    x_ret()
    # .dict — tail call to rt_dict_get (which expects rax=dict, rbx=key)
    ob_patch_u8(je_dict, ob_top - (je_dict + 1))
    alloc s := x_jmp_rel32_patchable()
    patch_rel32(s, dict_get_off)
    return entry
}

# STORE_INDEX dispatcher. Mirrors rt_index.
#
# Input:  rax = container, rbx = key, rdx = value
# Output: rax = container (passed through; dict_set may update header)
proc emit_rt_store_index(dict_set_off) {
    alloc entry := ob_top
    # mov rcx, [rax]
    ob_bytes([72, 139, 8])
    # cmp rcx, 1
    ob_bytes([72, 131, 249, 1])
    ob_byte(116)
    alloc je_list := ob_top
    ob_byte(0)
    # cmp rcx, 2
    ob_bytes([72, 131, 249, 2])
    ob_byte(116)
    alloc je_dict := ob_top
    ob_byte(0)
    # panic
    x_mov_imm32(REG_RAX, 60)
    x_mov_imm32(REG_RDI, 3)
    x_syscall()
    # .list — untag, write
    ob_patch_u8(je_list, ob_top - (je_list + 1))
    # sar rbx, 1
    ob_bytes([72, 209, 251])
    # mov [rax + 24 + rbx*8], rdx
    # ModR/M: mod=01, reg=010 (rdx), rm=100 → 0x54; SIB=0xd8; disp8=24
    ob_bytes([72, 137, 84, 216, 24])
    x_ret()
    # .dict — tail call to rt_dict_set (rax=dict, rbx=key, rdx=value)
    ob_patch_u8(je_dict, ob_top - (je_dict + 1))
    alloc s := x_jmp_rel32_patchable()
    patch_rel32(s, dict_set_off)
    return entry
}

# === Phase 7 — exception helpers ========================================
# Three runtime helpers cooperate through a single `except_top` slot
# at heap_base (the first 8 bytes of the heap region). The slot holds
# a pointer to the next free byte of the exception handler stack — a
# separate zero-filled region at the high end of memory. Each handler
# record is 40 bytes: [handler_addr, r15, r14, r12, rsp].
#
# Every helper starts with `mov rcx, imm64 (except_top_slot_vaddr)`
# whose imm64 is recorded in except_slot_patch_sites and resolved by
# finalize_elf once heap_base is known.

# === Phase 8b — floats ==================================================
# Float values are heap-allocated boxes: [type=5, f64_bits] (16 bytes).
# Arithmetic uses SSE2 scalar double instructions (movsd, addsd, etc.)
# operating on xmm0/xmm1. Boxing pulls in rt_alloc for each result —
# no value-types for floats yet; phase 11 may add NaN-boxing.
#
# Polymorphic ADD/SUB/MUL/DIV/NEG:
#   • int+int → existing inline fast path (gen_<op>'s int branch)
#   • everything else → calls rt_<op>_full which handles:
#       float+float, int+float, float+int — promotes int to f64
#                                            via cvtsi2sd, then opsd
#       (ADD only) str+str / list+list → tail-jmp to rt_concat
#       anything else → exit(4) [primitive type error]

# rt_box_float(xmm0 = double) → rax = pointer to new float box.
proc emit_rt_box_float(alloc_off) {
    alloc entry := ob_top
    # Save xmm0 across alloc (rt_alloc only touches integer regs but
    # we're paranoid since future helpers may use SSE).
    # sub rsp, 16 — 48 83 ec 10
    ob_bytes([72, 131, 236, 16])
    # movsd [rsp], xmm0 — f2 0f 11 04 24
    ob_bytes([242, 15, 17, 4, 36])
    # mov rax, 16
    x_mov_imm32(REG_RAX, 16)
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # movsd xmm0, [rsp] — f2 0f 10 04 24
    ob_bytes([242, 15, 16, 4, 36])
    # add rsp, 16
    ob_bytes([72, 131, 196, 16])
    # mov qword [rax], 5 (HEAP_T_FLOAT)
    ob_bytes([72, 199, 0, 5, 0, 0, 0])
    # movsd [rax + 8], xmm0 — f2 0f 11 40 08
    ob_bytes([242, 15, 17, 64, 8])
    x_ret()
    return entry
}

# Promote two operands to xmm0 and xmm1 as f64s. Returns via ret;
# on error (non-numeric inputs) exits with code 4. For ADD's slow
# path, the caller checks for the string/list case BEFORE calling
# this helper.
#
# Input:  rax = lhs, rbx = rhs (at least one non-int already; if both
#         heap, they must both be HEAP_T_FLOAT).
# Output: xmm0 = lhs as f64, xmm1 = rhs as f64
proc emit_rt_promote_floats() {
    alloc entry := ob_top
    # test al, 1 — a8 01
    ob_bytes([168, 1])
    # jnz lhs_int (rel8) — 75 ??
    ob_byte(117)
    alloc jnz_lhs_int := ob_top
    ob_byte(0)
    # lhs is heap, must be float. movsd xmm0, [rax + 8]
    ob_bytes([242, 15, 16, 64, 8])
    # test bl, 1
    ob_bytes([246, 195, 1])
    # jnz lhs_heap_rhs_int (rel8)
    ob_byte(117)
    alloc jnz_rhs_int := ob_top
    ob_byte(0)
    # both heap; rhs must be float. movsd xmm1, [rbx + 8]
    ob_bytes([242, 15, 16, 75, 8])
    x_ret()
    # lhs heap (float), rhs int → promote rbx to xmm1
    ob_patch_u8(jnz_rhs_int, ob_top - (jnz_rhs_int + 1))
    # sar rbx, 1
    x_sar_rbx_1()
    # cvtsi2sd xmm1, rbx — f2 48 0f 2a cb
    ob_bytes([242, 72, 15, 42, 203])
    x_ret()
    # lhs int, rhs heap (float) → promote rax to xmm0
    ob_patch_u8(jnz_lhs_int, ob_top - (jnz_lhs_int + 1))
    # sar rax, 1
    x_sar_rax_1()
    # cvtsi2sd xmm0, rax — f2 48 0f 2a c0
    ob_bytes([242, 72, 15, 42, 192])
    # rhs must be heap float
    # movsd xmm1, [rbx + 8]
    ob_bytes([242, 15, 16, 75, 8])
    x_ret()
    return entry
}

# Common prologue for arithmetic helpers that DON'T fall through to
# concat: promote both operands to xmm0/xmm1, apply the SSE op, box.
# `op_byte_a`, `op_byte_b`, `op_byte_c`, `op_byte_d` encode the SSE
# instruction (4 bytes for addsd/subsd/mulsd/divsd — first 3 are
# `f2 0f <opcode>` and the last is `c1` = ModR/M for xmm0,xmm1).
proc emit_rt_arith_full_numeric(promote_off, box_off, op_byte_a, op_byte_b, op_byte_c, op_byte_d) {
    alloc entry := ob_top
    alloc s_prom := x_call_rel32_patchable()
    patch_call_rel32(s_prom, promote_off)
    ob_bytes([op_byte_a, op_byte_b, op_byte_c, op_byte_d])
    alloc s_box := x_jmp_rel32_patchable()
    patch_rel32(s_box, box_off)
    return entry
}

# rt_add_full additionally falls through to rt_concat for non-float
# heap-heap operand pairs (string+string, list+list). All other
# non-int-int combinations promote-and-add as floats.
proc emit_rt_add_full(promote_off, box_off, concat_off) {
    alloc entry := ob_top
    # If both operands are heap (LSB=0 on both) AND lhs's type isn't
    # float, defer to rt_concat.
    ob_bytes([168, 1])                       # test al, 1
    ob_byte(117)
    alloc jnz_skip := ob_top
    ob_byte(0)
    ob_bytes([246, 195, 1])                  # test bl, 1
    ob_byte(117)
    alloc jnz_skip2 := ob_top
    ob_byte(0)
    # Both heap. Check lhs type.
    ob_bytes([72, 139, 8])                   # mov rcx, [rax]
    ob_bytes([72, 131, 249, 5])              # cmp rcx, HEAP_T_FLOAT
    ob_byte(116)
    alloc je_promote := ob_top
    ob_byte(0)
    # lhs is non-float heap (string/list); defer to rt_concat.
    alloc s_c := x_jmp_rel32_patchable()
    patch_rel32(s_c, concat_off)
    # je_promote target: fall through to promote+addsd+box.
    ob_patch_u8(je_promote, ob_top - (je_promote + 1))
    ob_patch_u8(jnz_skip,   ob_top - (jnz_skip + 1))
    ob_patch_u8(jnz_skip2,  ob_top - (jnz_skip2 + 1))
    alloc s_prom := x_call_rel32_patchable()
    patch_call_rel32(s_prom, promote_off)
    ob_bytes([242, 15, 88, 193])             # addsd xmm0, xmm1
    alloc s_box := x_jmp_rel32_patchable()
    patch_rel32(s_box, box_off)
    return entry
}

# Negate a float: rax = float ptr → rax = new boxed -value. For int,
# the inline fast path already handles negation; this is the slow path.
proc emit_rt_neg_full(box_off) {
    alloc entry := ob_top
    # Input: rax = heap pointer; must be float
    # mov rcx, [rax]; cmp rcx, 5; jne err
    ob_bytes([72, 139, 8])
    ob_bytes([72, 131, 249, 5])
    ob_byte(117)
    alloc jne_err := ob_top
    ob_byte(0)
    # xorpd xmm1, xmm1 — zero xmm1
    ob_bytes([102, 15, 87, 201])
    # movsd xmm0, [rax + 8]
    ob_bytes([242, 15, 16, 64, 8])
    # subsd xmm1, xmm0 — xmm1 = 0 - value
    ob_bytes([242, 15, 92, 200])
    # movsd xmm0, xmm1 — f2 0f 10 c1
    ob_bytes([242, 15, 16, 193])
    alloc s_box := x_jmp_rel32_patchable()
    patch_rel32(s_box, box_off)
    # err
    ob_patch_u8(jne_err, ob_top - (jne_err + 1))
    x_mov_imm32(REG_RAX, 60)
    x_mov_imm32(REG_RDI, 4)
    x_syscall()
    return entry
}

# rt_emit_float: format a double to stdout (no trailing newline).
# Output format: `<integer>.<6-digit-fraction>` with trailing zeros
# trimmed (keeping at least one digit). Won't match Rust's Ryu-like
# output for transcendental fractions but covers the common cases
# (1.0, 1.5, 3.14, etc.).
#
# Input: rax = pointer to a HEAP_T_FLOAT box.
proc emit_rt_emit_float(off_int) {
    alloc entry := ob_top
    # Allocate a 16-byte scratch on native stack for digit buffer.
    ob_bytes([72, 131, 236, 16])             # sub rsp, 16
    # movsd xmm0, [rax + 8] — load the float value
    ob_bytes([242, 15, 16, 64, 8])
    # Test sign: xorpd xmm1, xmm1; ucomisd xmm0, xmm1; jae positive
    ob_bytes([102, 15, 87, 201])             # xorpd xmm1, xmm1
    ob_bytes([102, 15, 46, 193])             # ucomisd xmm0, xmm1
    ob_byte(115)                              # jae positive (rel8)
    alloc jae_pos := ob_top
    ob_byte(0)
    # Negative: write '-' and negate xmm0.
    # mov byte [rsp + 8], '-' — c6 44 24 08 2d (ModR/M 44 SIB 24 disp8 8)
    ob_bytes([198, 68, 36, 8, 45])
    # Save xmm0 to stack (rt_emit_int uses xmm-untouched syscalls, but
    # we keep it conservative).
    ob_bytes([242, 15, 17, 4, 36])           # movsd [rsp], xmm0
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    ob_bytes([72, 141, 116, 36, 8])          # lea rsi, [rsp + 8]
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    ob_bytes([242, 15, 16, 4, 36])           # movsd xmm0, [rsp]
    # Negate: xorpd xmm1, xmm1; subsd xmm1, xmm0; movapd xmm0, xmm1
    ob_bytes([102, 15, 87, 201])             # xorpd xmm1, xmm1
    ob_bytes([242, 15, 92, 200])             # subsd xmm1, xmm0
    ob_bytes([242, 15, 16, 193])             # movsd xmm0, xmm1
    ob_patch_u8(jae_pos, ob_top - (jae_pos + 1))
    # xmm0 is now non-negative. Extract integer part to rax.
    ob_bytes([242, 72, 15, 44, 192])         # cvttsd2si rax, xmm0
    # Save xmm0 to stack across rt_emit_int (which is a CALL).
    ob_bytes([242, 15, 17, 4, 36])           # movsd [rsp], xmm0
    ob_byte(80)                              # push rax (save int_part)
    # Re-tag and emit integer part (no newline).
    x_sal_rax_1()
    x_or_rax_imm8(1)
    alloc s_int := x_call_rel32_patchable()
    patch_call_rel32(s_int, off_int)
    ob_byte(88)                              # pop rax (int_part)
    ob_bytes([242, 15, 16, 4, 36])           # movsd xmm0, [rsp]
    # Compute fractional part: xmm0 -= (double)int_part
    ob_bytes([242, 72, 15, 42, 200])         # cvtsi2sd xmm1, rax
    ob_bytes([242, 15, 92, 193])             # subsd xmm0, xmm1
    # Write '.' using [rsp + 8] as a 1-byte buffer.
    ob_bytes([198, 68, 36, 8, 46])           # mov byte [rsp+8], '.'
    ob_bytes([242, 15, 17, 4, 36])           # movsd [rsp], xmm0
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    ob_bytes([72, 141, 116, 36, 8])          # lea rsi, [rsp + 8]
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    ob_bytes([242, 15, 16, 4, 36])           # movsd xmm0, [rsp]
    # Compute 6 fractional digits into bytes at [rsp..rsp+6).
    x_mov_imm32(REG_RCX, 10)
    ob_bytes([242, 72, 15, 42, 209])         # cvtsi2sd xmm2, rcx (= 10.0)
    ob_bytes([72, 49, 255])                  # xor rdi, rdi (digit index)
    alloc dloop := ob_top
    ob_bytes([242, 15, 89, 194])             # mulsd xmm0, xmm2
    ob_bytes([242, 72, 15, 44, 192])         # cvttsd2si rax, xmm0
    ob_bytes([242, 72, 15, 42, 200])         # cvtsi2sd xmm1, rax
    ob_bytes([242, 15, 92, 193])             # subsd xmm0, xmm1
    ob_bytes([72, 131, 192, 48])             # add rax, '0'
    # mov [rsp + rdi], al  — ModR/M 04 SIB 3c
    ob_bytes([136, 4, 60])
    ob_bytes([72, 255, 199])                 # inc rdi
    ob_bytes([72, 131, 255, 6])              # cmp rdi, 6
    ob_byte(124)                              # jl dloop
    ob_byte((dloop - (ob_top + 1)) & 255)
    # Trim trailing zeros: while rdi > 1 and [rsp + rdi - 1] == '0': rdi--
    alloc trim_loop := ob_top
    ob_bytes([72, 131, 255, 1])              # cmp rdi, 1
    ob_byte(126)                              # jle done_trim
    alloc jle_done := ob_top
    ob_byte(0)
    # mov al, [rsp + rdi - 1]
    # ModR/M: mod=01, reg=000, rm=100 (SIB) → 0x44
    # SIB:    scale=00, index=111(rdi), base=100(rsp) → 0x3c
    # disp8 = -1 = 0xff
    ob_bytes([138, 68, 60, 255])
    ob_bytes([60, 48])                       # cmp al, '0'
    ob_byte(117)                              # jne done_trim
    alloc jne_done := ob_top
    ob_byte(0)
    ob_bytes([72, 255, 207])                 # dec rdi
    ob_byte(235)                              # jmp trim_loop
    ob_byte((trim_loop - (ob_top + 1)) & 255)
    ob_patch_u8(jle_done, ob_top - (jle_done + 1))
    ob_patch_u8(jne_done, ob_top - (jne_done + 1))
    # Save the digit count BEFORE clobbering rdi for the syscall.
    # mov rdx, rdi (count)
    ob_bytes([72, 137, 250])
    # mov rsi, rsp (buffer)
    ob_bytes([72, 137, 230])
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_syscall()
    ob_bytes([72, 131, 196, 16])             # add rsp, 16
    x_ret()
    return entry
}

# === Phase 8 — builtins =================================================
# A grab-bag of small helpers, one per non-trivial builtin. Each takes
# its argument(s) from registers (the gen_builtin caller pops the
# operand stack into the expected registers and pushes the result).

# rt_chr(rax = tagged int) → rax = heap string of length 1 containing
# that byte. Allocates 17 bytes (16 header + 1 data), then a small
# round-up pad happens in rt_alloc-aware sites elsewhere.
proc emit_rt_chr(alloc_off) {
    alloc entry := ob_top
    # sar rax, 1  (untag)
    x_sar_rax_1()
    # push rax  (save byte value)
    ob_byte(80)
    # mov rax, 24  (16 hdr + 1 byte rounded up to 8 for cleanliness)
    x_mov_imm32(REG_RAX, 24)
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # pop rcx  (byte value)
    ob_byte(89)
    # mov qword [rax], 0  (type = string)
    ob_bytes([72, 199, 0, 0, 0, 0, 0])
    # mov qword [rax + 8], 1  (length = 1) — 48 c7 40 08 01 00 00 00
    ob_bytes([72, 199, 64, 8, 1, 0, 0, 0])
    # mov [rax + 16], cl  — 88 48 10
    ob_bytes([136, 72, 16])
    x_ret()
    return entry
}

# rt_list_repeat(rax = item, rcx = count untagged) → rax = list ptr
# of N items all set to the same value.
proc emit_rt_list_repeat(alloc_off) {
    alloc entry := ob_top
    # Save item and count on native stack.
    ob_byte(80)                          # push rax (item)
    ob_byte(81)                          # push rcx (count)
    # Compute size = 24 + count*8
    # mov rax, rcx — 48 89 c8
    ob_bytes([72, 137, 200])
    # shl rax, 3 — 48 c1 e0 03
    ob_bytes([72, 193, 224, 3])
    # add rax, 24 — 48 83 c0 18
    ob_bytes([72, 131, 192, 24])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # pop rcx (count); pop rdx (item)
    ob_byte(89)
    ob_byte(90)
    # Write header [type=1, length, capacity]
    ob_bytes([72, 199, 0, 1, 0, 0, 0])
    # mov [rax + 8], rcx
    ob_bytes([72, 137, 72, 8])
    # mov [rax + 16], rcx
    ob_bytes([72, 137, 72, 16])
    # If count == 0 we're done.
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)                          # jz forward
    alloc jz_site := ob_top
    ob_byte(0)
    # Loop: i = 0; while i < count: [rax + 24 + i*8] = rdx; i++
    ob_bytes([72, 49, 246])               # xor rsi, rsi (i = 0)
    alloc loop_start := ob_top
    # mov [rax + 24 + rsi*8], rdx
    # ModR/M: mod=01, reg=010(rdx), rm=100(SIB) → 0x54
    # SIB:    scale=11 (×8), index=110(rsi), base=000(rax) → 0xf0
    # disp8 = 24
    ob_bytes([72, 137, 84, 240, 24])
    # inc rsi — 48 ff c6
    ob_bytes([72, 255, 198])
    # cmp rsi, rcx — 48 39 ce
    ob_bytes([72, 57, 206])
    # jl loop_start (rel8 backward)
    ob_byte(124)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    ob_patch_u8(jz_site, ob_top - (jz_site + 1))
    x_ret()
    return entry
}

# rt_dict_keys(rax = dict ptr) → rax = list of keys.
proc emit_rt_dict_keys(alloc_off) {
    alloc entry := ob_top
    # mov rcx, [rax + 8]  (length)
    ob_bytes([72, 139, 72, 8])
    # mov r8, rax  (save dict)
    ob_bytes([73, 137, 192])
    ob_byte(81)                           # push rcx
    # alloc size = 24 + length*8
    # mov rax, rcx; shl rax, 3; add rax, 24
    ob_bytes([72, 137, 200])
    ob_bytes([72, 193, 224, 3])
    ob_bytes([72, 131, 192, 24])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    ob_byte(89)                           # pop rcx
    # Header
    ob_bytes([72, 199, 0, 1, 0, 0, 0])
    ob_bytes([72, 137, 72, 8])
    ob_bytes([72, 137, 72, 16])
    # Copy keys: for i in [0, length): list[i] = dict.entry[i].key
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)
    alloc jz_site := ob_top
    ob_byte(0)
    ob_bytes([72, 49, 246])               # xor rsi, rsi (i = 0)
    alloc loop_start := ob_top
    # entry i at [r8 + 24 + i*16]. i*16 = i<<4 (scale 8 max, so do
    # *8 SIB and then add another i*8 explicitly via lea/shl).
    # Simpler: rdi = i*16; rdi = i<<4.
    # mov rdi, rsi; shl rdi, 4
    ob_bytes([72, 137, 247])              # mov rdi, rsi
    ob_bytes([72, 193, 231, 4])           # shl rdi, 4
    # rdx = [r8 + rdi + 24]  (key field)
    # ModR/M: mod=01, reg=010(rdx), rm=100(SIB) → 0x54
    # SIB:    scale=00, index=111(rdi), base=000(r8 with REX.B) → 0x38
    # REX: W + B = 49 (no X needed since rdi is low-8)
    ob_bytes([73, 139, 84, 56, 24])
    # mov [rax + rsi*8 + 24], rdx
    # SIB: scale=11, index=110(rsi), base=000(rax) → 0xf0
    ob_bytes([72, 137, 84, 240, 24])
    ob_bytes([72, 255, 198])              # inc rsi
    ob_bytes([72, 57, 206])               # cmp rsi, rcx
    ob_byte(124)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    ob_patch_u8(jz_site, ob_top - (jz_site + 1))
    x_ret()
    return entry
}

# rt_bytes_to_string(rax = list of tagged ints) → rax = string ptr.
# Each list element's low 8 bits become a byte in the new string.
proc emit_rt_bytes_to_string(alloc_off) {
    alloc entry := ob_top
    ob_bytes([72, 139, 72, 8])            # mov rcx, [rax + 8]
    ob_bytes([73, 137, 192])              # mov r8, rax
    ob_byte(81)                           # push rcx
    # size = 16 + length, rounded to 8
    ob_bytes([72, 137, 200])              # mov rax, rcx
    ob_bytes([72, 131, 192, 23])          # add rax, 23
    ob_bytes([72, 131, 224, 248])         # and rax, -8
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    ob_byte(89)                           # pop rcx
    ob_bytes([72, 199, 0, 0, 0, 0, 0])    # type = 0
    ob_bytes([72, 137, 72, 8])            # length
    # Loop over list elements
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)
    alloc jz_site := ob_top
    ob_byte(0)
    ob_bytes([72, 49, 246])               # xor rsi, rsi
    alloc loop_start := ob_top
    # rdi = [r8 + 24 + rsi*8] (tagged int)
    # ModR/M: mod=01, reg=111(rdi), rm=100(SIB) → 0x7c
    # SIB:    scale=11 (×8), index=110(rsi), base=000(r8+REX.B) → 0xf0
    ob_bytes([73, 139, 124, 240, 24])
    # sar rdi, 1 — 48 d1 ff
    ob_bytes([72, 209, 255])
    # mov [rax + rsi + 16], dil
    # REX: 40 (need REX so dil is dil and not bh)
    # 88 = mov r/m8, r8
    # ModR/M: mod=01, reg=111(dil), rm=100(SIB) → 0x7c
    # SIB:    scale=00, index=110(rsi), base=000(rax) → 0x30
    # disp8 = 16
    ob_bytes([64, 136, 124, 48, 16])
    ob_bytes([72, 255, 198])              # inc rsi
    ob_bytes([72, 57, 206])               # cmp rsi, rcx
    ob_byte(124)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    ob_patch_u8(jz_site, ob_top - (jz_site + 1))
    x_ret()
    return entry
}

# rt_string_bytes(rax = string ptr) → rax = list of tagged ints.
# Each byte of the string becomes a tagged int element.
proc emit_rt_string_bytes(alloc_off) {
    alloc entry := ob_top
    ob_bytes([72, 139, 72, 8])            # mov rcx, [rax + 8] (length)
    ob_bytes([73, 137, 192])              # mov r8, rax
    ob_byte(81)                           # push rcx
    ob_bytes([72, 137, 200])              # mov rax, rcx
    ob_bytes([72, 193, 224, 3])           # shl rax, 3
    ob_bytes([72, 131, 192, 24])          # add rax, 24
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    ob_byte(89)                           # pop rcx
    ob_bytes([72, 199, 0, 1, 0, 0, 0])    # type=1
    ob_bytes([72, 137, 72, 8])
    ob_bytes([72, 137, 72, 16])
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)
    alloc jz_site := ob_top
    ob_byte(0)
    ob_bytes([72, 49, 246])               # xor rsi, rsi
    alloc loop_start := ob_top
    # movzx rdi, byte [r8 + rsi + 16]
    # 49 0f b6 7c 30 10:
    # 49 REX.W + REX.B
    # 0f b6 movzx
    # ModR/M: mod=01, reg=111(rdi), rm=100(SIB) → 0x7c
    # SIB:    scale=00, index=110(rsi), base=000(r8+B) → 0x30
    ob_bytes([73, 15, 182, 124, 48, 16])
    # shl rdi, 1; or rdi, 1
    ob_bytes([72, 209, 231])              # shl rdi, 1
    ob_bytes([72, 131, 207, 1])           # or rdi, 1
    # mov [rax + rsi*8 + 24], rdi
    # ModR/M: mod=01, reg=111(rdi), rm=100(SIB) → 0x7c
    # SIB:    scale=11, index=110(rsi), base=000(rax) → 0xf0
    ob_bytes([72, 137, 124, 240, 24])
    ob_bytes([72, 255, 198])
    ob_bytes([72, 57, 206])
    ob_byte(124)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    ob_patch_u8(jz_site, ob_top - (jz_site + 1))
    x_ret()
    return entry
}

# rt_str_to_int(rax = string ptr) → rax = tagged int.
# Parses a base-10 signed integer. Handles optional leading '-'.
# No whitespace handling, no error checking beyond what the bytecode
# would catch — trusts the input format.
proc emit_rt_str_to_int() {
    alloc entry := ob_top
    ob_bytes([72, 139, 72, 8])            # mov rcx, [rax + 8] (length)
    ob_bytes([72, 141, 112, 16])          # lea rsi, [rax + 16] (bytes)
    ob_bytes([72, 49, 210])               # xor rdx, rdx (accumulator)
    ob_bytes([72, 49, 255])               # xor rdi, rdi (sign flag)
    # if length == 0: result = 0 → tagged 1
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)
    alloc jz_done := ob_top
    ob_byte(0)
    # Check sign: cmp byte [rsi], '-' (45)
    ob_bytes([128, 62, 45])               # cmp byte [rsi], 0x2d
    ob_byte(117)                          # jne forward (skip sign-flag set)
    alloc jne_no_sign := ob_top
    ob_byte(0)
    # rdi = 1, rsi += 1, rcx -= 1
    ob_bytes([72, 199, 199, 1, 0, 0, 0])  # mov rdi, 1
    ob_bytes([72, 255, 198])              # inc rsi
    ob_bytes([72, 255, 201])              # dec rcx
    ob_patch_u8(jne_no_sign, ob_top - (jne_no_sign + 1))
    # Loop: while rcx > 0: digit = [rsi] - '0'; rdx = rdx*10 + digit
    alloc loop_start := ob_top
    ob_bytes([72, 133, 201])              # test rcx, rcx
    ob_byte(116)
    alloc jz_apply := ob_top
    ob_byte(0)
    # movzx r8, byte [rsi]
    ob_bytes([76, 15, 182, 6])            # 4c 0f b6 06
    # sub r8, 48
    ob_bytes([73, 131, 232, 48])          # 49 83 e8 30
    # imul rdx, rdx, 10
    ob_bytes([72, 107, 210, 10])          # 48 6b d2 0a
    # add rdx, r8
    ob_bytes([76, 1, 194])                # 4c 01 c2
    ob_bytes([72, 255, 198])              # inc rsi
    ob_bytes([72, 255, 201])              # dec rcx
    ob_byte(235)                          # jmp loop_start (rel8 back)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    ob_patch_u8(jz_apply, ob_top - (jz_apply + 1))
    # Apply sign
    ob_bytes([72, 133, 255])              # test rdi, rdi
    ob_byte(116)
    alloc jz_pos := ob_top
    ob_byte(0)
    ob_bytes([72, 247, 218])              # neg rdx
    ob_patch_u8(jz_pos, ob_top - (jz_pos + 1))
    # Tag rdx and put in rax
    ob_bytes([72, 209, 226])              # shl rdx, 1
    ob_bytes([72, 131, 202, 1])           # or rdx, 1
    ob_bytes([72, 137, 208])              # mov rax, rdx
    x_ret()
    ob_patch_u8(jz_done, ob_top - (jz_done + 1))
    # length=0 path: return tagged 0 = 1
    x_mov_imm32(REG_RAX, 1)
    x_ret()
    return entry
}

# Push a new handler record. Caller puts the handler's absolute
# virtual address into rax, then `call rt_setup_except`.
proc emit_rt_setup_except() {
    alloc entry := ob_top
    # push rax — preserve handler_addr through the slot load
    ob_byte(80)
    # mov rcx, imm64 (slot_addr) — patched at finalize
    ob_bytes([72, 185])
    alloc slot_site := ob_top
    ob_u64(0)
    except_slot_patch_sites := except_slot_patch_sites + [slot_site]
    # mov rdx, [rcx] — rdx = current except_top
    ob_bytes([72, 139, 17])
    # pop rax (restore handler_addr)
    ob_byte(88)
    # mov [rdx], rax — handler_addr
    ob_bytes([72, 137, 2])
    # mov [rdx + 8], r15 — 4c 89 7a 08
    ob_bytes([76, 137, 122, 8])
    # mov [rdx + 16], r14 — 4c 89 72 10
    ob_bytes([76, 137, 114, 16])
    # mov [rdx + 24], r12 — 4c 89 62 18
    ob_bytes([76, 137, 98, 24])
    # mov [rdx + 32], rsp — 48 89 62 20
    ob_bytes([72, 137, 98, 32])
    # add rdx, 40 — 48 83 c2 28
    ob_bytes([72, 131, 194, 40])
    # mov [rcx], rdx
    ob_bytes([72, 137, 17])
    x_ret()
    return entry
}

# Pop the top handler record (decrement except_top by 40 bytes).
# Used by POP_BLOCK opcode and by RET / BREAK unwind paths.
proc emit_rt_pop_block() {
    alloc entry := ob_top
    ob_bytes([72, 185])
    alloc slot_site := ob_top
    ob_u64(0)
    except_slot_patch_sites := except_slot_patch_sites + [slot_site]
    # mov rdx, [rcx]
    ob_bytes([72, 139, 17])
    # sub rdx, 40
    ob_bytes([72, 131, 234, 40])
    # mov [rcx], rdx
    ob_bytes([72, 137, 17])
    x_ret()
    return entry
}

# Unwind via the top handler. Input: rax = exception value (caller
# popped it off the operand stack). Decrements except_top, restores
# (r15, r14, r12, rsp) from the popped record, pushes rax onto the
# restored operand stack, then `jmp <handler_addr>`. Does not return.
proc emit_rt_raise() {
    alloc entry := ob_top
    ob_bytes([72, 185])
    alloc slot_site := ob_top
    ob_u64(0)
    except_slot_patch_sites := except_slot_patch_sites + [slot_site]
    # mov rdx, [rcx]
    ob_bytes([72, 139, 17])
    # sub rdx, 40
    ob_bytes([72, 131, 234, 40])
    # mov [rcx], rdx — write the new (decremented) top back
    ob_bytes([72, 137, 17])
    # mov rbx, [rdx] — rbx = handler_addr
    ob_bytes([72, 139, 26])
    # mov r15, [rdx + 8] — 4c 8b 7a 08
    ob_bytes([76, 139, 122, 8])
    # mov r14, [rdx + 16] — 4c 8b 72 10
    ob_bytes([76, 139, 114, 16])
    # mov r12, [rdx + 24] — 4c 8b 62 18
    ob_bytes([76, 139, 98, 24])
    # mov rsp, [rdx + 32] — 48 8b 62 20 (NOTE: rsp is restored last —
    # this throws away the native frame of rt_raise itself, which is
    # fine since we're about to jmp, not ret)
    ob_bytes([72, 139, 98, 32])
    # sub r15, 8 — 49 83 ef 08
    ob_bytes([73, 131, 239, 8])
    # mov [r15], rax — 49 89 07
    ob_bytes([73, 137, 7])
    # jmp rbx — ff e3
    ob_bytes([255, 227])
    return entry
}

# Format a dict as `{key: value, key: value}` to stdout (no trailing
# newline; the print dispatcher adds it). Mirrors rt_emit_list but
# with two-element entries and a ": " separator between key and value.
# Mutually recursive with rt_emit_dispatch_repr via a patched call site.
# Returns [entry, patch_site_for_dispatch_repr].
proc emit_rt_emit_dict(addr_lbrace, addr_rbrace, addr_comma, addr_colon) {
    alloc entry := ob_top
    # push rax (dict ptr)
    ob_byte(80)
    # write "{"
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_lbrace)
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    # pop rax
    ob_byte(88)
    # rcx = length
    ob_bytes([72, 139, 72, 8])
    # test rcx, rcx
    ob_bytes([72, 133, 201])
    # jz .close (rel8)
    ob_byte(116)
    alloc jz_close := ob_top
    ob_byte(0)
    # rdx = 0 (i)
    ob_bytes([72, 49, 210])
    # Save the dispatch_repr call site for caller-side patching.
    alloc dispatch_site := 0
    alloc loop_start := ob_top
    # Save rax, rcx, rdx
    ob_bytes([80, 81, 82])
    # rax = key = [rax + 24 + rdx*16]
    # 24 + rdx*16: SIB can do *8 max, so do it as rax + 24 + (rdx*2)*8
    # Easier: rax = old_rax + 24 + rdx*16 in two steps using a temp.
    # mov r8, rdx — 49 89 d0
    ob_bytes([73, 137, 208])
    # shl r8, 4 — 49 c1 e0 04 (r8 = rdx * 16)
    ob_bytes([73, 193, 224, 4])
    # mov rax, [rax + r8 + 24]
    # ModR/M: mod=01, reg=000(rax), rm=100(SIB) → 0x44
    # SIB:    scale=00(×1), index=000(r8 with REX.X), base=000(rax)
    # REX: W + X (index extension) = 4a
    ob_bytes([74, 139, 68, 0, 24])
    # call rt_emit_dispatch_repr (rel32 placeholder)
    ob_byte(232)
    dispatch_site := ob_top
    ob_u32(0)
    # Write ": "
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_colon)
    x_mov_imm32(REG_RDX, 2)
    x_syscall()
    # Restore rax (dict), rcx (length), rdx (i)
    ob_bytes([90, 89, 88])
    # Now print the value. Save state again.
    ob_bytes([80, 81, 82])
    # rax = value = [dict + 32 + rdx*16]  (entry start at 24 + rdx*16, value at +8)
    ob_bytes([73, 137, 208])     # mov r8, rdx
    ob_bytes([73, 193, 224, 4])  # shl r8, 4
    # mov rax, [rax + r8 + 32]
    ob_bytes([74, 139, 68, 0, 32])
    # call rt_emit_dispatch_repr
    ob_byte(232)
    alloc dispatch_site2 := ob_top
    ob_u32(0)
    # Restore
    ob_bytes([90, 89, 88])
    # i += 1, check if last
    # inc rdx — 48 ff c2
    ob_bytes([72, 255, 194])
    # cmp rdx, rcx — 48 39 ca
    ob_bytes([72, 57, 202])
    # jge .close (rel8)
    ob_byte(125)
    alloc jge_close := ob_top
    ob_byte(0)
    # Write ", "
    ob_bytes([80, 81, 82])
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_comma)
    x_mov_imm32(REG_RDX, 2)
    x_syscall()
    ob_bytes([90, 89, 88])
    # jmp loop_start (backward rel8)
    ob_byte(235)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    # .close — patch jumps
    alloc close_off := ob_top
    ob_patch_u8(jz_close, close_off - (jz_close + 1))
    ob_patch_u8(jge_close, close_off - (jge_close + 1))
    # Write "}"
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_rbrace)
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    x_ret()
    return [entry, dispatch_site, dispatch_site2]
}

# Compare two heap strings for byte-equality. Standard repe cmpsb
# pattern: lengths must match first, then byte-by-byte compare.
#
# Input:  rax = string A, rbx = string B
# Output: ZF=1 if equal, ZF=0 otherwise
# Clobbers: rcx, rdx, rsi, rdi
proc emit_rt_str_eq() {
    alloc entry := ob_top
    # mov rdx, [rax + 8] (len_a)
    ob_bytes([72, 139, 80, 8])
    # cmp rdx, [rbx + 8] (len_b)
    ob_bytes([72, 59, 83, 8])
    # jne .neq (rel8 placeholder)
    ob_byte(117)
    alloc jne_site := ob_top
    ob_byte(0)
    # lea rsi, [rax + 16]
    ob_bytes([72, 141, 112, 16])
    # lea rdi, [rbx + 16]
    ob_bytes([72, 141, 123, 16])
    # mov rcx, rdx
    ob_bytes([72, 137, 209])
    # repe cmpsb — f3 a6 (2 bytes; clobbers rcx/rsi/rdi)
    ob_bytes([243, 166])
    # The ret leaves ZF set by repe cmpsb.
    x_ret()
    # .neq: ZF=0 (from the jne we just took). Just ret with that.
    ob_patch_u8(jne_site, ob_top - (jne_site + 1))
    x_ret()
    return entry
}

# Build a dict from the top 2N operand-stack values (N key-value pairs).
# The top of the stack holds the LAST pair's value, with pairs ordered
# [k0, v0, k1, v1, ..., k_{N-1}, v_{N-1}] bottom-to-top.
#
# Layout: [type=2, length=N, capacity, k0, v0, k1, v1, ...]. Each entry
# is 16 bytes (key + value). Capacity is set to N + 8 so a handful of
# new keys can be added via STORE_INDEX without an immediate resize;
# proper grow logic lands later.
#
# Input:  rax = N (number of pairs)
# Output: rax = pointer to new dict
proc emit_rt_build_dict(alloc_off) {
    alloc entry := ob_top
    # Save N on native stack.
    ob_byte(80)                              # push rax
    # capacity = N + 8 → into rcx, save.
    # add rax, 8 — 48 83 c0 08
    ob_bytes([72, 131, 192, 8])
    ob_byte(80)                              # push rax (capacity)
    # size = capacity * 16 + 24
    # shl rax, 4 — 48 c1 e0 04
    ob_bytes([72, 193, 224, 4])
    # add rax, 24 — 48 83 c0 18
    ob_bytes([72, 131, 192, 24])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # rax = dict ptr.
    ob_byte(89)                              # pop rcx (capacity)
    ob_byte(90)                              # pop rdx (N)
    # Write header: type=2, length=N, capacity.
    # mov qword [rax], 2 — 48 c7 00 02 00 00 00
    ob_bytes([72, 199, 0, 2, 0, 0, 0])
    # mov [rax + 8], rdx — 48 89 50 08
    ob_bytes([72, 137, 80, 8])
    # mov [rax + 16], rcx — 48 89 48 10
    ob_bytes([72, 137, 72, 16])
    # If N == 0 we're done.
    # test rdx, rdx — 48 85 d2
    ob_bytes([72, 133, 210])
    # jz .done (rel8 placeholder)
    ob_byte(116)
    alloc jz_done_site := ob_top
    ob_byte(0)
    # rcx = pointer to entry N-1 = rax + 24 + (N-1)*16
    # mov rcx, rdx — 48 89 d1
    ob_bytes([72, 137, 209])
    # dec rcx — 48 ff c9
    ob_bytes([72, 255, 201])
    # shl rcx, 4 — 48 c1 e1 04
    ob_bytes([72, 193, 225, 4])
    # add rcx, 24 — 48 83 c1 18
    ob_bytes([72, 131, 193, 24])
    # add rcx, rax — 48 01 c1
    ob_bytes([72, 1, 193])
    alloc loop_start := ob_top
    # Pop value into r8.
    # mov r8, [r15] — 4d 8b 07
    ob_bytes([77, 139, 7])
    # add r15, 8 — 49 83 c7 08
    ob_bytes([73, 131, 199, 8])
    # Pop key into r9.
    # mov r9, [r15] — 4d 8b 0f
    ob_bytes([77, 139, 15])
    # add r15, 8
    ob_bytes([73, 131, 199, 8])
    # mov [rcx], r9 (key)
    # 4c 89 09: REX.WR, 89, ModR/M(mod=00, reg=r9(001+REX.R), rm=rcx(001)) = 11_001_001 = 0x09 — wait, mod=00 means [rcx] no disp. So 09 = 00_001_001 ✓
    ob_bytes([76, 137, 9])
    # mov [rcx + 8], r8 (value)
    # 4c 89 41 08: REX.WR, 89, ModR/M(mod=01, reg=r8(000+REX.R), rm=rcx(001)) = 01_000_001 = 0x41, disp8=8
    ob_bytes([76, 137, 65, 8])
    # sub rcx, 16 — 48 83 e9 10
    ob_bytes([72, 131, 233, 16])
    # dec rdx — 48 ff ca
    ob_bytes([72, 255, 202])
    # jnz loop_start (backward rel8)
    ob_byte(117)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    # .done
    ob_patch_u8(jz_done_site, ob_top - (jz_done_site + 1))
    x_ret()
    return entry
}

# Dict get by string key. Linear scan over entries.
#
# Input:  rax = dict ptr, rbx = key ptr (heap string)
# Output: rax = value, or program exits with status 1 if key missing
# Clobbers: rcx, rdx, rsi, rdi, r8
proc emit_rt_dict_get(str_eq_off) {
    alloc entry := ob_top
    # rcx = length (entries count)
    # mov rcx, [rax + 8] — 48 8b 48 08
    ob_bytes([72, 139, 72, 8])
    # test rcx, rcx
    ob_bytes([72, 133, 201])
    # jz .miss (rel8)
    ob_byte(116)
    alloc jz_miss := ob_top
    ob_byte(0)
    # r8 = pointer to first entry = rax + 24
    # lea r8, [rax + 24] — 4c 8d 40 18
    ob_bytes([76, 141, 64, 24])
    alloc loop_start := ob_top
    # Save state: rax (dict), rbx (key), rcx (counter), r8 (entry ptr)
    ob_bytes([80, 83, 81])                   # push rax/rbx/rcx
    ob_bytes([65, 80])                       # push r8 (41 50)
    # Compare [r8] (entry key) with rbx (target key)
    # mov rax, [r8] — 49 8b 00
    ob_bytes([73, 139, 0])
    # rbx already holds the target key
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, str_eq_off)
    # Restore state. NOTE: pop sets RFLAGS not affected, ZF preserved.
    ob_bytes([65, 88])                       # pop r8 (41 58)
    ob_bytes([89, 91, 88])                   # pop rcx/rbx/rax
    # je .found (rel8)
    ob_byte(116)
    alloc je_found := ob_top
    ob_byte(0)
    # Advance entry pointer + decrement counter
    # add r8, 16 — 49 83 c0 10
    ob_bytes([73, 131, 192, 16])
    # dec rcx — 48 ff c9
    ob_bytes([72, 255, 201])
    # jnz loop_start
    ob_byte(117)
    ob_byte((loop_start - (ob_top + 1)) & 255)
    # .miss — write nothing, exit(1)
    ob_patch_u8(jz_miss, ob_top - (jz_miss + 1))
    x_mov_imm32(REG_RAX, 60)
    x_mov_imm32(REG_RDI, 1)
    x_syscall()
    # .found — return [r8 + 8]
    ob_patch_u8(je_found, ob_top - (je_found + 1))
    # mov rax, [r8 + 8] — 49 8b 40 08
    ob_bytes([73, 139, 64, 8])
    x_ret()
    return entry
}

# Dict set: update if key exists, otherwise append (panicking when at
# capacity — phase 5e doesn't grow). Returns the dict pointer.
#
# Input:  rax = dict ptr, rbx = key ptr, rdx = value
# Output: rax = dict ptr (unchanged)
# Clobbers: rcx, rsi, rdi, r8
proc emit_rt_dict_set(str_eq_off) {
    alloc entry := ob_top
    # Save dict ptr in r9 for later use.
    # mov r9, rax — 49 89 c1
    ob_bytes([73, 137, 193])
    # rcx = length
    # mov rcx, [rax + 8]
    ob_bytes([72, 139, 72, 8])
    # test rcx, rcx
    ob_bytes([72, 133, 201])
    # jz .append (rel8 — we'll patch it for skip)
    ob_byte(116)
    alloc jz_append := ob_top
    ob_byte(0)
    # r8 = pointer to first entry
    # lea r8, [rax + 24]
    ob_bytes([76, 141, 64, 24])
    alloc scan_start := ob_top
    # Save state across rt_str_eq
    ob_bytes([80, 83, 81, 82])                # push rax/rbx/rcx/rdx
    ob_bytes([65, 80])                        # push r8
    # mov rax, [r8] (entry key)
    ob_bytes([73, 139, 0])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, str_eq_off)
    ob_bytes([65, 88])                        # pop r8
    ob_bytes([90, 89, 91, 88])                # pop rdx/rcx/rbx/rax
    # je .found (rel8)
    ob_byte(116)
    alloc je_found := ob_top
    ob_byte(0)
    # add r8, 16
    ob_bytes([73, 131, 192, 16])
    # dec rcx
    ob_bytes([72, 255, 201])
    # jnz scan_start
    ob_byte(117)
    ob_byte((scan_start - (ob_top + 1)) & 255)
    # .append
    ob_patch_u8(jz_append, ob_top - (jz_append + 1))
    # Reload length + capacity from dict
    # mov rcx, [r9 + 8] — 49 8b 49 08 (length)
    ob_bytes([73, 139, 73, 8])
    # mov rdi, [r9 + 16] — 49 8b 79 10 (capacity)
    ob_bytes([73, 139, 121, 16])
    # cmp rcx, rdi — 48 39 f9
    ob_bytes([72, 57, 249])
    # jb .has_room (rel8) — jb because unsigned
    ob_byte(114)
    alloc jb_room := ob_top
    ob_byte(0)
    # capacity exhausted — exit(2). Phase 8 will grow instead.
    x_mov_imm32(REG_RAX, 60)
    x_mov_imm32(REG_RDI, 2)
    x_syscall()
    # .has_room
    ob_patch_u8(jb_room, ob_top - (jb_room + 1))
    # r8 = pointer to entry slot at index `length`
    # lea r8, [rcx*8]
    ob_bytes([76, 141, 4, 205, 0, 0, 0, 0])  # 4c 8d 04 cd <disp32=0>
    # shl r8, 1 — 49 d1 e0   (r8 = length * 16)
    ob_bytes([73, 209, 224])
    # add r8, 24 — 49 83 c0 18
    ob_bytes([73, 131, 192, 24])
    # add r8, r9 — 4d 01 c8
    ob_bytes([77, 1, 200])
    # inc length: mov [r9 + 8], rcx after rcx+1
    # inc rcx — 48 ff c1
    ob_bytes([72, 255, 193])
    # mov [r9 + 8], rcx — 49 89 49 08
    ob_bytes([73, 137, 73, 8])
    # Fall through to common write block below (.found is the same).
    # .found:
    ob_patch_u8(je_found, ob_top - (je_found + 1))
    # mov [r8], rbx (key)
    # 49 89 18: REX.WB, 89, ModR/M(mod=00, reg=rbx(011), rm=r8(000+REX.B)) = 0x18
    ob_bytes([73, 137, 24])
    # mov [r8 + 8], rdx (value)
    # 49 89 50 08: ModR/M(mod=01, reg=rdx(010), rm=r8(000+REX.B)) = 0x50, disp8=8
    ob_bytes([73, 137, 80, 8])
    # mov rax, r9 (return dict ptr, unchanged)
    ob_bytes([76, 137, 200])
    x_ret()
    return entry
}

# Concatenate two heap-typed values of the same shape into a new
# heap-allocated value. Dispatches by lhs's type tag:
#   type=0 (string) → byte-wise concat via rep movsb
#   type=1 (list)   → 8-byte concat via rep movsq
# Falls through to the string path for any other type (phase 5 trusts
# the bytecode; phase 8 will tighten with explicit type errors).
proc emit_rt_concat(string_off, list_off) {
    alloc entry := ob_top
    # mov rcx, [rax] — 48 8b 08 (type tag of lhs)
    ob_bytes([72, 139, 8])
    # cmp rcx, 1 — 48 83 f9 01
    ob_bytes([72, 131, 249, 1])
    # je <list_path> (rel32 placeholder)
    ob_bytes([15, 132])
    alloc je_site := ob_top
    ob_u32(0)
    # jmp string_concat (tail call — string's ret returns straight to
    # gen_add's caller).
    alloc s := x_jmp_rel32_patchable()
    patch_rel32(s, string_off)
    # List path entry — patch the je above.
    patch_rel32(je_site, ob_top)
    # jmp list_concat (tail call)
    alloc l := x_jmp_rel32_patchable()
    patch_rel32(l, list_off)
    return entry
}

# Concatenate two lists into a new heap-allocated list. Mirrors
# rt_string_concat but with 8-byte element copies (rep movsq) and the
# list header layout [type=1, length, capacity, elements...].
#
# Input:  rax = lhs pointer, rbx = rhs pointer (both are heap lists)
# Output: rax = pointer to new concatenated list
# Clobbers: rcx, rdx, rsi, rdi, r8
proc emit_rt_list_concat(alloc_off) {
    alloc entry := ob_top
    # mov rcx, [rax + 8] — 48 8b 48 08 (len_a)
    ob_bytes([72, 139, 72, 8])
    # mov rdx, [rbx + 8] — 48 8b 53 08 (len_b)
    ob_bytes([72, 139, 83, 8])
    # push rax (lhs); push rbx (rhs)
    ob_bytes([80, 83])
    # add rcx, rdx — 48 01 d1 (total length)
    ob_bytes([72, 1, 209])
    # push rcx (save total length)
    ob_byte(81)
    # Compute size: 24 + total*8 (no extra padding — 8-aligned
    # naturally because each slot is 8 bytes and 24 is 8-aligned).
    # shl rcx, 3 — 48 c1 e1 03
    ob_bytes([72, 193, 225, 3])
    # add rcx, 24 — 48 83 c1 18
    ob_bytes([72, 131, 193, 24])
    # mov rax, rcx — 48 89 c8
    ob_bytes([72, 137, 200])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # mov r8, rax (save new ptr) — 49 89 c0
    ob_bytes([73, 137, 192])
    # pop rdi (total length); pop rbx (rhs); pop rsi (lhs)
    ob_bytes([95, 91, 94])
    # Header: type=1, length=total, capacity=total
    # mov qword [r8], 1 — 49 c7 00 01 00 00 00
    ob_bytes([73, 199, 0, 1, 0, 0, 0])
    # mov [r8 + 8], rdi — 49 89 78 08
    ob_bytes([73, 137, 120, 8])
    # mov [r8 + 16], rdi — 49 89 78 10
    ob_bytes([73, 137, 120, 16])
    # Copy lhs elements with rep movsq.
    # rsi already = lhs; bump it past header. Set rcx = len_a,
    # rdi = newptr + 24.
    # mov rcx, [rsi + 8] — 48 8b 4e 08
    ob_bytes([72, 139, 78, 8])
    # add rsi, 24 — 48 83 c6 18
    ob_bytes([72, 131, 198, 24])
    # lea rdi, [r8 + 24] — 49 8d 78 18
    ob_bytes([73, 141, 120, 24])
    # rep movsq — f3 48 a5
    ob_bytes([243, 72, 165])
    # Copy rhs elements.
    # mov rcx, [rbx + 8] — 48 8b 4b 08
    ob_bytes([72, 139, 75, 8])
    # mov rsi, rbx — 48 89 de
    ob_bytes([72, 137, 222])
    # add rsi, 24 — 48 83 c6 18
    ob_bytes([72, 131, 198, 24])
    # rep movsq
    ob_bytes([243, 72, 165])
    # Return new ptr.
    # mov rax, r8 — 4c 89 c0
    ob_bytes([76, 137, 192])
    x_ret()
    return entry
}

# Concatenate two strings into a new heap-allocated string.
#
# Input:  rax = lhs pointer, rbx = rhs pointer (both are heap strings)
# Output: rax = pointer to new concatenated string
# Clobbers: rcx, rdx, rsi, rdi, r8
#
# Layout matches the existing heap-string convention:
# [type=0:u64][length:u64][bytes...]. Bytes are copied with rep movsb,
# which keeps the helper compact (~80 bytes).
proc emit_rt_string_concat(alloc_off) {
    alloc entry := ob_top
    # Read lengths.
    # mov rcx, [rax + 8] — 48 8b 48 08 (len_a)
    ob_bytes([72, 139, 72, 8])
    # mov rdx, [rbx + 8] — 48 8b 53 08 (len_b)
    ob_bytes([72, 139, 83, 8])
    # Save lhs and rhs onto native stack so we can clobber them.
    ob_byte(80)                       # push rax (lhs)
    ob_byte(83)                       # push rbx (rhs)
    # Total length = len_a + len_b → into rcx.
    # add rcx, rdx — 48 01 d1
    ob_bytes([72, 1, 209])
    # push rcx (save total length).
    ob_byte(81)
    # Alloc size = total + 16 (header) + 7, rounded down to ×8.
    # add rcx, 23 — 48 83 c1 17
    ob_bytes([72, 131, 193, 23])
    # and rcx, -8 — 48 83 e1 f8
    ob_bytes([72, 131, 225, 248])
    # mov rax, rcx — 48 89 c8
    ob_bytes([72, 137, 200])
    # call rt_alloc
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # Restore: r8 = new ptr (save it before clobbering rax), then pop
    # rdi = total length, rbx = rhs, rsi = lhs.
    # mov r8, rax — 49 89 c0
    ob_bytes([73, 137, 192])
    ob_byte(95)                       # pop rdi (total length)
    ob_byte(91)                       # pop rbx (rhs)
    # pop rsi (lhs into rsi for the upcoming rep movsb)
    ob_byte(94)
    # Write header on new string: [type=0, length=total]
    # mov qword [r8], 0 — 49 c7 00 00 00 00 00
    ob_bytes([73, 199, 0, 0, 0, 0, 0])
    # mov [r8 + 8], rdi — 49 89 78 08
    ob_bytes([73, 137, 120, 8])
    # First rep movsb: copy lhs bytes. rsi already = lhs; bump it past
    # the header, point rdi at dest+16, set rcx = len_a.
    # mov rcx, [rsi + 8] — 48 8b 4e 08
    ob_bytes([72, 139, 78, 8])
    # add rsi, 16 — 48 83 c6 10
    ob_bytes([72, 131, 198, 16])
    # lea rdi, [r8 + 16] — 49 8d 78 10
    ob_bytes([73, 141, 120, 16])
    # rep movsb — f3 a4
    ob_bytes([243, 164])
    # Second rep movsb: copy rhs bytes. rdi is already positioned at
    # dest+16+len_a; set rsi=rhs+16, rcx=len_b.
    # mov rcx, [rbx + 8] — 48 8b 4b 08
    ob_bytes([72, 139, 75, 8])
    # mov rsi, rbx — 48 89 de
    ob_bytes([72, 137, 222])
    # add rsi, 16 — 48 83 c6 10
    ob_bytes([72, 131, 198, 16])
    # rep movsb
    ob_bytes([243, 164])
    # Return r8 in rax.
    # mov rax, r8 — 4c 89 c0
    ob_bytes([76, 137, 192])
    x_ret()
    return entry
}

# Build a list from the top N operand-stack values. Layout matches
# heap-object convention: [type=1, length=N, capacity=N, elem_0..N-1].
# The LAST pushed value becomes element N-1 (so the source `[1,2,3]`
# emits PushInt(1), PushInt(2), PushInt(3), BuildList(3) and ends with
# list[0]=1, list[1]=2, list[2]=3).
#
# Input:  rax = N (number of elements; non-negative, fits in 32 bits)
# Output: rax = pointer to the new list header
# Clobbers: rcx, rdx
proc emit_rt_build_list(alloc_off) {
    alloc entry := ob_top
    # push rax — save N onto native stack while we go through rt_alloc
    ob_byte(80)
    # shl rax, 3 — 48 c1 e0 03 (rax *= 8)
    ob_bytes([72, 193, 224, 3])
    # add rax, 24 — 48 83 c0 18 (header overhead)
    ob_bytes([72, 131, 192, 24])
    # call rt_alloc — rax in (size) → rax out (pointer)
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, alloc_off)
    # pop rcx — restore N into rcx
    ob_byte(89)
    # mov qword [rax], 1                 ; type = HEAP_T_LIST
    ob_bytes([72, 199, 0, 1, 0, 0, 0])
    # mov [rax + 8], rcx                 ; length
    ob_bytes([72, 137, 72, 8])
    # mov [rax + 16], rcx                ; capacity
    ob_bytes([72, 137, 72, 16])
    # Copy N elements from operand stack into the new list array.
    # The top of operand stack (last pushed) becomes element N-1.
    # If N is zero, skip the loop entirely.
    # test rcx, rcx — 48 85 c9
    ob_bytes([72, 133, 201])
    # jz +N (to .done; we'll patch this once we know the loop size)
    ob_byte(116)
    alloc jz_site := ob_top
    ob_byte(0)
    # dec rcx — 48 ff c9 (now rcx = N - 1, the last valid index)
    ob_bytes([72, 255, 201])
    alloc loop_start := ob_top
    # mov rdx, [r15] — 49 8b 17
    ob_bytes([73, 139, 23])
    # add r15, 8 — 49 83 c7 08
    ob_bytes([73, 131, 199, 8])
    # mov [rax + 24 + rcx*8], rdx — 48 89 54 c8 18
    ob_bytes([72, 137, 84, 200, 24])
    # dec rcx — 48 ff c9
    ob_bytes([72, 255, 201])
    # jns loop_start — 79 <rel8>
    ob_byte(121)
    alloc back := loop_start - (ob_top + 1)
    ob_byte(back & 255)
    # Patch the earlier jz to skip the loop entirely on N=0.
    alloc skip_size := ob_top - (jz_site + 1)
    ob_patch_u8(jz_site, skip_size)
    x_ret()
    return entry
}

# Emit a small helper that writes a fixed virtual-address string of
# fixed length to stdout, then ret. Used for the sentinel value
# printers (true / false / none) and for the bracket/comma/newline
# punctuation that surrounds list output. Returns the helper's entry
# offset.
proc emit_rt_write_static(addr, len) {
    alloc entry := ob_top
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr)
    x_mov_imm32(REG_RDX, len)
    x_syscall()
    x_ret()
    return entry
}

# Recursive list formatter: writes `[elem0, elem1, ..., elemN-1]` to
# stdout using rt_emit_dispatch_repr for each element. The dispatcher
# offset is forward-referenced (the dispatcher is emitted after this
# helper because the dispatcher needs *this* helper's offset for its
# list case — mutual recursion). Returns [entry, patch_site] so the
# caller can patch the `call rt_emit_dispatch_repr` site once the
# dispatcher's offset is known.
#
# Input:  rax = pointer to a HEAP_T_LIST object
# Output: nothing (writes to stdout); rax clobbered
proc emit_rt_emit_list(addr_lbrack, addr_rbrack, addr_comma) {
    alloc entry := ob_top
    # push rax (save list ptr while we issue the "[" syscall)
    ob_byte(80)
    # mov rax, 1; mov rdi, 1; mov rsi, <addr_lbrack>; mov rdx, 1; syscall
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_lbrack)
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    # pop rax (restore list ptr)
    ob_byte(88)
    # mov rcx, [rax + 8]  — 48 8b 48 08 (length)
    ob_bytes([72, 139, 72, 8])
    # test rcx, rcx — 48 85 c9
    ob_bytes([72, 133, 201])
    # jz close (forward rel8, patched after we know close's offset)
    ob_byte(116)
    alloc jz_close_site := ob_top
    ob_byte(0)
    # xor rdx, rdx — 48 31 d2  (i = 0)
    ob_bytes([72, 49, 210])
    alloc loop_start := ob_top
    # push rax, push rcx, push rdx (save iteration state)
    ob_bytes([80, 81, 82])
    # mov rax, [rax + 24 + rdx*8] — 48 8b 44 d0 18
    ob_bytes([72, 139, 68, 208, 24])
    # call rt_emit_dispatch_repr (rel32, patched by caller)
    ob_byte(232)
    alloc dispatch_call_site := ob_top
    ob_u32(0)
    # pop rdx, pop rcx, pop rax (restore iteration state)
    ob_bytes([90, 89, 88])
    # inc rdx — 48 ff c2
    ob_bytes([72, 255, 194])
    # cmp rdx, rcx — 48 39 ca
    ob_bytes([72, 57, 202])
    # jge close (forward rel8, patched)
    ob_byte(125)
    alloc jge_close_site := ob_top
    ob_byte(0)
    # push rax, push rcx, push rdx (save for the ", " syscall)
    ob_bytes([80, 81, 82])
    # mov rax, 1; mov rdi, 1; mov rsi, addr_comma; mov rdx, 2; syscall
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_comma)
    x_mov_imm32(REG_RDX, 2)
    x_syscall()
    # pop rdx, pop rcx, pop rax
    ob_bytes([90, 89, 88])
    # jmp loop_start (backward rel8)
    ob_byte(235)
    alloc back := loop_start - (ob_top + 1)
    ob_byte(back & 255)
    # close: write "]" and ret
    alloc close_off := ob_top
    # Patch the two forward jz/jge sites
    ob_patch_u8(jz_close_site, close_off - (jz_close_site + 1))
    ob_patch_u8(jge_close_site, close_off - (jge_close_site + 1))
    x_mov_imm32(REG_RAX, 1)
    x_mov_imm32(REG_RDI, 1)
    x_mov_imm64(REG_RSI, addr_rbrack)
    x_mov_imm32(REG_RDX, 1)
    x_syscall()
    x_ret()
    return [entry, dispatch_call_site]
}

# Repr dispatcher: writes a value's textual representation to stdout
# WITHOUT a trailing newline. The newline is added once by
# rt_emit_dispatch_print at the top of every EMIT, so element renders
# inside a list don't insert newlines mid-output.
#
# Branches by tag:
#   LSB=1                       → rt_emit_int     (small integer)
#   == TAG_FALSE/TAG_TRUE/TAG_NONE → matching sentinel writer
#   otherwise (heap pointer)    → check type tag at [rax]:
#                                  type=HEAP_T_STRING → rt_emit_str
#                                  type=HEAP_T_LIST   → rt_emit_list
proc emit_rt_emit_dispatch_repr(off_int, off_str, off_false, off_true, off_none, off_list, off_dict, off_float) {
    alloc entry := ob_top
    ob_bytes([168, 1])
    ob_bytes([116, 5])
    alloc s_int := x_jmp_rel32_patchable()
    patch_rel32(s_int, off_int)
    x_cmp_rax_imm8(TAG_FALSE)
    alloc s_false := x_je_rel32_patchable()
    patch_rel32(s_false, off_false)
    x_cmp_rax_imm8(TAG_TRUE)
    alloc s_true := x_je_rel32_patchable()
    patch_rel32(s_true, off_true)
    x_cmp_rax_imm8(TAG_NONE)
    alloc s_none := x_je_rel32_patchable()
    patch_rel32(s_none, off_none)
    # Heap pointer — read type tag at [rax]
    ob_bytes([72, 139, 8])                   # mov rcx, [rax]
    ob_bytes([72, 131, 249, 1])              # cmp rcx, HEAP_T_LIST
    alloc s_list := x_je_rel32_patchable()
    patch_rel32(s_list, off_list)
    ob_bytes([72, 131, 249, 2])              # cmp rcx, HEAP_T_DICT
    alloc s_dict := x_je_rel32_patchable()
    patch_rel32(s_dict, off_dict)
    ob_bytes([72, 131, 249, 5])              # cmp rcx, HEAP_T_FLOAT
    alloc s_float := x_je_rel32_patchable()
    patch_rel32(s_float, off_float)
    # Default: assume HEAP_T_STRING → jmp rt_emit_str
    alloc s_str := x_jmp_rel32_patchable()
    patch_rel32(s_str, off_str)
    return entry
}

# Print dispatcher: writes a value's repr, then a single trailing
# newline. This is the public EMIT entry; user code's `Emit` opcode
# compiles to `call rt_emit_dispatch_print`.
proc emit_rt_emit_dispatch_print(off_repr, off_newline) {
    alloc entry := ob_top
    # call rt_emit_dispatch_repr (rax is preserved for free — repr
    # helpers happen to clobber rax, but we don't need it after).
    alloc s_repr := x_call_rel32_patchable()
    patch_call_rel32(s_repr, off_repr)
    # jmp rt_emit_newline (tail call — newline's ret returns to the
    # caller of dispatch_print).
    alloc s_nl := x_jmp_rel32_patchable()
    patch_rel32(s_nl, off_newline)
    return entry
}

# Layout the runtime blob: static strings first (so we know their
# absolute virtual addresses immediately), then the helpers. Returns
# the dispatcher's offset — that's what user code's EMIT sites call.
# Helpers used by other opcodes (rt_alloc, rt_build_list,
# rt_string_concat) get their offsets stashed in globals so codegen
# can patch the rel32s later.
alloc rt_alloc_off          := 0
alloc rt_build_list_off     := 0
alloc rt_concat_off         := 0
alloc rt_slice_off          := 0
alloc rt_build_dict_off     := 0
alloc rt_dict_get_off       := 0
alloc rt_dict_set_off       := 0
alloc rt_index_off          := 0
alloc rt_store_index_off    := 0
alloc rt_setup_except_off   := 0
alloc rt_pop_block_off      := 0
alloc rt_raise_off          := 0
alloc rt_chr_off            := 0
alloc rt_list_repeat_off    := 0
alloc rt_dict_keys_off      := 0
alloc rt_bytes_to_string_off := 0
alloc rt_string_bytes_off   := 0
alloc rt_str_to_int_off     := 0
alloc rt_emit_dispatch_repr_off := 0   # used by print() to emit without newline
alloc rt_box_float_off       := 0
alloc rt_add_full_off        := 0
alloc rt_sub_full_off        := 0
alloc rt_mul_full_off        := 0
alloc rt_div_full_off        := 0
alloc rt_neg_full_off        := 0
alloc rt_emit_float_off      := 0

# Patch sites for the imm64 of `mov rcx, imm64 (except_top_slot_addr)`
# that's emitted inside each except helper. Resolved in finalize_elf
# once the slot's absolute virtual address is known (= heap_base).
alloc except_slot_patch_sites := []
# Patch sites for the imm64 in the entry-point prologue's
# `mov rcx, imm64 (slot); mov rax, imm64 (except_base); mov [rcx], rax`
# init sequence.
alloc except_init_slot_site    := 0
alloc except_init_base_site    := 0

proc emit_runtime_blob() {
    # Static strings — no trailing newlines (those come from the
    # newline writer at the end of each EMIT). Lengths: true=4,
    # false=5, none=4; punctuation 1/1/2/1/2 for [/]/", "/{/}/": "/newline 1.
    alloc addr_true   := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("true")
    alloc addr_false  := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("false")
    alloc addr_none   := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("none")
    alloc addr_lbrack := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("[")
    alloc addr_rbrack := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("]")
    alloc addr_comma  := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes(", ")
    alloc addr_lbrace := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("{")
    alloc addr_rbrace := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("}")
    alloc addr_colon  := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes(": ")
    alloc addr_nl     := ELF_BASE + HEADERS_SIZE + ob_top
    ob_string_bytes("\n")
    pad_to_8()
    # Leaf repr helpers (no trailing newlines).
    alloc off_int     := emit_rt_emit_int()
    alloc off_str     := emit_rt_emit_str()
    alloc off_true    := emit_rt_write_static(addr_true,  4)
    alloc off_false   := emit_rt_write_static(addr_false, 5)
    alloc off_none    := emit_rt_write_static(addr_none,  4)
    # Allocator + builders.
    rt_alloc_off          := emit_rt_alloc()
    rt_build_list_off     := emit_rt_build_list(rt_alloc_off)
    alloc str_concat_off  := emit_rt_string_concat(rt_alloc_off)
    alloc list_concat_off := emit_rt_list_concat(rt_alloc_off)
    rt_concat_off         := emit_rt_concat(str_concat_off, list_concat_off)
    rt_slice_off          := emit_rt_slice(rt_alloc_off)
    rt_build_dict_off     := emit_rt_build_dict(rt_alloc_off)
    # Dict get/set need string equality.
    alloc str_eq_off      := emit_rt_str_eq()
    rt_dict_get_off       := emit_rt_dict_get(str_eq_off)
    rt_dict_set_off       := emit_rt_dict_set(str_eq_off)
    rt_index_off          := emit_rt_index(rt_dict_get_off)
    rt_store_index_off    := emit_rt_store_index(rt_dict_set_off)
    # Exception helpers (phase 7).
    rt_setup_except_off   := emit_rt_setup_except()
    rt_pop_block_off      := emit_rt_pop_block()
    rt_raise_off          := emit_rt_raise()
    # Builtin helpers (phase 8).
    rt_chr_off            := emit_rt_chr(rt_alloc_off)
    rt_list_repeat_off    := emit_rt_list_repeat(rt_alloc_off)
    rt_dict_keys_off      := emit_rt_dict_keys(rt_alloc_off)
    rt_bytes_to_string_off := emit_rt_bytes_to_string(rt_alloc_off)
    rt_string_bytes_off   := emit_rt_string_bytes(rt_alloc_off)
    rt_str_to_int_off     := emit_rt_str_to_int()
    # Float helpers (phase 8b).
    rt_box_float_off      := emit_rt_box_float(rt_alloc_off)
    alloc rt_promote_off  := emit_rt_promote_floats()
    rt_add_full_off       := emit_rt_add_full(rt_promote_off, rt_box_float_off, rt_concat_off)
    rt_sub_full_off       := emit_rt_arith_full_numeric(rt_promote_off, rt_box_float_off, 242, 15, 92, 193)
    rt_mul_full_off       := emit_rt_arith_full_numeric(rt_promote_off, rt_box_float_off, 242, 15, 89, 193)
    rt_div_full_off       := emit_rt_arith_full_numeric(rt_promote_off, rt_box_float_off, 242, 15, 94, 193)
    rt_neg_full_off       := emit_rt_neg_full(rt_box_float_off)
    # Mutually-recursive list/dict emitters ↔ repr dispatcher.
    # Emit list/dict first with placeholder call sites for repr
    # dispatch, then emit the dispatcher (which can reference list +
    # dict directly), then patch the placeholders.
    alloc list_result    := emit_rt_emit_list(addr_lbrack, addr_rbrack, addr_comma)
    alloc rt_emit_list_off := list_result[0]
    alloc list_patch     := list_result[1]
    alloc dict_result    := emit_rt_emit_dict(addr_lbrace, addr_rbrace, addr_comma, addr_colon)
    alloc rt_emit_dict_off := dict_result[0]
    alloc dict_patch_key := dict_result[1]
    alloc dict_patch_val := dict_result[2]
    rt_emit_float_off := emit_rt_emit_float(off_int)
    alloc off_repr := emit_rt_emit_dispatch_repr(off_int, off_str, off_false, off_true, off_none, rt_emit_list_off, rt_emit_dict_off, rt_emit_float_off)
    rt_emit_dispatch_repr_off := off_repr
    patch_call_rel32(list_patch, off_repr)
    patch_call_rel32(dict_patch_key, off_repr)
    patch_call_rel32(dict_patch_val, off_repr)
    # Newline writer and the public print dispatcher.
    alloc off_newline    := emit_rt_write_static(addr_nl, 1)
    alloc off_print      := emit_rt_emit_dispatch_print(off_repr, off_newline)
    return off_print
}

# === Codegen ==============================================================

# Deferred string headers: [text, patch_site_for_addr]. The patch_site
# is the file offset of the imm64 inside a `mov rax, imm64` that should
# end up being the absolute virtual address of the string header.
alloc deferred_strings := []

# Tagged-int construction for a 64-bit OMG int. We always emit the
# 10-byte `mov rax, imm64` form for simplicity; phase-2-internal code
# fits comfortably in our binaries.
proc encode_tagged_int(n) {
    # (n << 1) | 1, masked to 64 bits. Negative values sign-extend
    # naturally in two's-complement, which is what we want.
    return ((n << 1) | 1) & 18446744073709551615
}

# Patchable 10-byte `mov rax, imm64`. Returns the offset of the imm64
# field so the caller can fill in the absolute string-header address
# during the data-layout pass.
proc x_mov_rax_imm64_patchable() {
    ob_byte(72)
    ob_byte(184 + REG_RAX)
    alloc site := ob_top
    ob_u64(0)
    return site
}

proc gen_push_int(n) {
    x_mov_imm64(REG_RAX, encode_tagged_int(n))
    x_push_reg(REG_RAX)
}

# PUSH_FLOAT(bits): the bytecode arg is the 64-bit IEEE-754 bit
# pattern stored as an i64. Move it into xmm0 via `movq xmm0, rax`,
# box, push the pointer.
proc gen_push_float(bits) {
    x_mov_imm64(REG_RAX, bits & 18446744073709551615)
    # movq xmm0, rax — 66 48 0f 6e c0
    ob_bytes([102, 72, 15, 110, 192])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_box_float_off)
    x_push_reg(REG_RAX)
}

proc gen_push_str(s) {
    alloc site := x_mov_rax_imm64_patchable()
    x_push_reg(REG_RAX)
    deferred_strings := deferred_strings + [[s, site]]
}

# Polymorphic ADD:
#   • int + int  → (a<<1|1) + (b<<1|1) - 1 = (a+b)<<1|1     (inline fast path)
#   • str + str  → rt_string_concat allocates a new heap string
#
# We tell the cases apart by ANDing the tag bits: both ints have
# LSB=1, so the AND has LSB=1; any other combination has LSB=0
# (heap pointers are 8-aligned). Falling through to rt_string_concat
# trusts the bytecode source — mixing int/string or pointing at a
# non-string heap object yields garbage in phase 5b. Will tighten in
# 5c when we add proper type checks.
proc gen_add() {
    x_pop_reg(REG_RBX)
    x_pop_reg(REG_RAX)
    x_mov_rcx_rax()
    x_and_rcx_rbx()
    x_test_cl_1()
    ob_bytes([117, 7])                       # jnz +7 (skip slow-path)
    # rt_add_full handles string-concat, list-concat, float+float,
    # and int↔float mixed arithmetic.
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_add_full_off)
    ob_bytes([235, 7])
    x_sub_rbx_imm8(1)
    x_add_rax_rbx()
    x_push_reg(REG_RAX)
}

# SUB: int fast path inline; otherwise rt_sub_full (float arithmetic).
proc gen_sub() {
    x_pop_reg(REG_RBX)
    x_pop_reg(REG_RAX)
    x_mov_rcx_rax()
    x_and_rcx_rbx()
    x_test_cl_1()
    ob_bytes([117, 7])                       # jnz +7
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_sub_full_off)
    ob_bytes([235, 7])
    # int fast path: tagged_a - tagged_b = (a-b)<<1, then OR the tag.
    x_sub_rax_rbx()                          # 3 bytes
    x_or_rax_imm8(1)                         # 4 bytes
    x_push_reg(REG_RAX)
}

# For MUL/DIV/MOD/NEG we untag inputs, operate on raw 63-bit values,
# then retag the result. Untagging via sar (arithmetic shift right)
# preserves sign for negative numbers.
proc gen_mul() {
    x_pop_reg(REG_RBX)
    x_pop_reg(REG_RAX)
    x_mov_rcx_rax()
    x_and_rcx_rbx()
    x_test_cl_1()
    ob_bytes([117, 7])                       # jnz +7 (skip slow path)
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_mul_full_off)
    ob_bytes([235, 17])                      # jmp +17 (skip int fast path)
    x_sar_rbx_1()                            # 3 bytes
    x_sar_rax_1()                            # 3 bytes
    x_imul_rax_rbx()                         # 4 bytes
    x_sal_rax_1()                            # 3 bytes
    x_or_rax_imm8(1)                         # 4 bytes
    x_push_reg(REG_RAX)
}

proc gen_div() {
    x_pop_reg(REG_RBX)
    x_pop_reg(REG_RAX)
    x_mov_rcx_rax()
    x_and_rcx_rbx()
    x_test_cl_1()
    ob_bytes([117, 7])
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_div_full_off)
    ob_bytes([235, 18])                      # jmp +18 (skip int fast path)
    x_sar_rbx_1()                            # 3 bytes
    x_sar_rax_1()                            # 3 bytes
    x_cqo()                                  # 2 bytes
    x_idiv_rbx()                             # 3 bytes
    x_sal_rax_1()                            # 3 bytes
    x_or_rax_imm8(1)                         # 4 bytes
    x_push_reg(REG_RAX)
}

proc gen_mod() {
    x_pop_reg(REG_RBX)
    x_sar_rbx_1()
    x_pop_reg(REG_RAX)
    x_sar_rax_1()
    x_cqo()
    x_idiv_rbx()
    x_mov_rax_rdx()                  # move remainder into rax for retag
    x_sal_rax_1()
    x_or_rax_imm8(1)
    x_push_reg(REG_RAX)
}

# NEG: int fast path inline; otherwise rt_neg_full (float negation).
proc gen_neg() {
    x_pop_reg(REG_RAX)
    # test al, 1
    ob_bytes([168, 1])
    ob_bytes([117, 7])                       # jnz +7
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_neg_full_off)
    ob_bytes([235, 11])                      # jmp +11 (skip int fast path)
    # int fast path: sub 1 (untag), neg, or 1 (retag)
    x_sub_rax_imm8(1)                        # 4
    x_neg_rax()                              # 3
    x_or_rax_imm8(1)                         # 4
    x_push_reg(REG_RAX)
}

# Phase-1 EMIT was an inline write syscall. Phase 2's EMIT pops a
# tagged value and calls the dispatcher, which routes by tag.
alloc emit_call_sites := []          # list of [site_offset, target_blob_offset]

proc gen_emit(dispatch_off) {
    x_pop_reg(REG_RAX)
    alloc site := x_call_rel32_patchable()
    emit_call_sites := emit_call_sites + [[site, dispatch_off]]
}

proc gen_halt() {
    x_xor_rdi_rdi()                  # exit code 0
    x_mov_imm32(REG_RAX, 60)         # sys_exit
    x_syscall()
}

# === Bools, none, comparisons ===========================================

proc gen_push_bool(b) {
    if b == true {
        x_mov_imm32(REG_RAX, TAG_TRUE)
    } else {
        x_mov_imm32(REG_RAX, TAG_FALSE)
    }
    x_push_reg(REG_RAX)
}

proc gen_push_none() {
    x_mov_imm32(REG_RAX, TAG_NONE)
    x_push_reg(REG_RAX)
}

# All comparison codegens share the same shape: pop two tagged ints,
# compare, materialise TAG_TRUE (4) in rax, materialise TAG_FALSE (2)
# in rcx, and use a conditional move to swap rcx into rax when the
# *inverse* of our condition holds. The mov+mov+cmov sequence avoids
# branching, keeping the prologue straight-line.
#
# Tagged ints (a<<1|1) and (b<<1|1) compare in the same order as the
# untagged values — the shared low bit cancels out — so we don't have
# to untag first.

proc gen_cmp_common() {
    x_pop_reg(REG_RBX)
    x_pop_reg(REG_RAX)
    x_cmp_rax_rbx()
    x_mov_imm32(REG_RAX, TAG_TRUE)
    x_mov_imm32(REG_RCX, TAG_FALSE)
}

proc gen_eq() { gen_cmp_common() x_cmovne_rax_rcx() x_push_reg(REG_RAX) }
proc gen_ne() { gen_cmp_common() x_cmove_rax_rcx()  x_push_reg(REG_RAX) }
proc gen_lt() { gen_cmp_common() x_cmovge_rax_rcx() x_push_reg(REG_RAX) }
proc gen_le() { gen_cmp_common() x_cmovg_rax_rcx()  x_push_reg(REG_RAX) }
proc gen_gt() { gen_cmp_common() x_cmovle_rax_rcx() x_push_reg(REG_RAX) }
proc gen_ge() { gen_cmp_common() x_cmovl_rax_rcx()  x_push_reg(REG_RAX) }

# NOT swaps TAG_TRUE <-> TAG_FALSE. Trick: 6 - rax. 6 - 4 = 2,
# 6 - 2 = 4. (Phase 3 doesn't handle truthiness of non-bool values.)
proc gen_not() {
    x_pop_reg(REG_RAX)
    x_mov_imm32(REG_RCX, 6)
    x_sub_rcx_rax()
    x_push_reg(REG_RCX)
}

# === Jumps ==============================================================
# Bytecode `JUMP(target_idx)` refers to a *bytecode instruction index*,
# not a machine offset. We don't know the machine offset of the target
# until we've emitted everything up to (and possibly past) it, so we
# emit a placeholder rel32 and record a patch site + target idx; after
# all code is emitted we walk the patches and fill in the right
# displacements.

alloc jump_patches := []     # list of [patch_site, target_bytecode_idx]
alloc instr_offsets := []    # instr_offsets[i] = ob_top before instr i's emit

proc gen_jump(target_idx) {
    alloc site := x_jmp_rel32_patchable()
    jump_patches := jump_patches + [[site, target_idx]]
}

# JUMP_IF_FALSE pops a value and jumps when it's a "falsy" sentinel.
# Phase 3 recognises three falsy values: TAG_FALSE (2), tagged-zero
# (1, from PUSH_INT 0), and TAG_NONE (6). Other values (TAG_TRUE,
# non-zero ints, all heap pointers) are truthy and fall through.
proc gen_jump_if_false(target_idx) {
    x_pop_reg(REG_RAX)
    x_cmp_rax_imm8(TAG_FALSE)
    alloc s1 := x_je_rel32_patchable()
    jump_patches := jump_patches + [[s1, target_idx]]
    x_cmp_rax_imm8(1)             # tagged 0
    alloc s2 := x_je_rel32_patchable()
    jump_patches := jump_patches + [[s2, target_idx]]
    x_cmp_rax_imm8(TAG_NONE)
    alloc s3 := x_je_rel32_patchable()
    jump_patches := jump_patches + [[s3, target_idx]]
}

# === Functions ==========================================================
# Phase 4 design: each OMG function compiles to a body that lives at a
# known machine offset. Direct calls (`Call("name")`) compile to a
# native `call rel32` patched after every body is emitted.
#
# Calling convention (left-to-right pushed, right-to-left consumed):
#   - Caller pushes args left-to-right onto the operand stack via r15.
#   - Caller native-CALLs the callee's entry. Native rsp gets the
#     return address. r15 still points at the rightmost arg.
#   - Callee prologue:
#       push r14                # save caller's frame pointer
#       mov  r14, r15           # establish current frame's anchor
#       sub  r15, N_locals*8    # reserve local slots
#   - param[i] (i = 0 is the LEFTMOST arg) is at [r14 + (N_args-1-i)*8]
#     because pushes grow the stack down; the leftmost push lands at
#     the highest address, the rightmost (last pushed) at the lowest.
#   - local[j] is at [r14 - (j+1)*8].
#   - Each `Ret` site emits the epilogue inline:
#       mov  rax, [r15]                       # pop the return value
#       lea  r15, [r14 + (N_args-1)*8]        # one slot below caller's r15
#       mov  [r15], rax                       # place return value
#       pop  r14                              # restore caller's frame
#       ret                                   # native return
#     Net effect: N_args slots replaced by 1 result slot on the operand
#     stack, so the caller sees the function call as a "pop N, push 1"
#     operation.

alloc current_func_params := []        # ordered param names of current fn
alloc current_func_locals := []        # ordered local names of current fn
alloc in_function := false             # codegen scope kind
alloc current_func_name   := ""        # name of the fn currently being emitted
alloc current_parent_name := ""        # parent fn's name (or "" if top-level proc)

# Pre-pass tables. Phase 6b captures the enclosing scope's params +
# locals into a closure's env when MAKE_FUNC runs; the inner function
# uses r12 to dereference free variables out of that env. Two tables
# drive the resolution:
#
#   func_parents:    list of [func_name, parent_name]   (parent="" for top-level procs)
#   func_scope_info: list of [func_name, params, locals]  (so a child can find
#                    its parent's variable layout for slot lookup)
alloc func_parents    := []
alloc func_scope_info := []

# Flat env layout per function. env_layout(f) is the list of names
# visible in f's closure's env, in the order they appear in env slots
# starting at [env+16]. The list is the concatenation of every
# ancestor's [params + locals], outermost-first. A function with no
# parent (top-level proc) has env_layout = []. With this table:
#
#   • `gen_make_func` knows how many slots to allocate in the child's
#     env and where each one's source value lives (the first
#     N=len(env_layout(parent)) slots come from r12+16 onwards; the
#     remaining slots come from r14 frame addresses).
#   • `scope_offset` resolves free variables by searching this flat
#     list — slot index = list position.
alloc func_env_layouts := []

# Function machine-entry offsets, indexed by mangled name. Used to
# resolve direct-call rel32 patches.
alloc fn_entry := []                   # list of [name, ob_top_offset]

# Outstanding Call/TCall sites to patch after all bodies have been
# emitted. Each entry is [patch_site, target_name].
alloc fn_call_patches := []

# MAKE_FUNC patch sites: the imm64 in the closure's `mov rcx, imm64`
# instruction that holds the function's machine-code entry address.
# Each entry is [patch_site_for_imm64, target_name].
alloc fn_closure_patches := []

proc fn_entry_set(name, offset) {
    fn_entry := fn_entry + [[name, offset]]
}

proc fn_entry_get(name) {
    alloc i := 0
    alloc n := length(fn_entry)
    loop i < n {
        if fn_entry[i][0] == name {
            return fn_entry[i][1]
        }
        i := i + 1
    }
    panic("native-asm: no function entry for '" + name + "'")
}

# Look up `name`. Returns one of:
#   ["local", byte_offset]   — params/locals of the current function;
#                              caller emits [r14 + offset] access.
#   ["free", slot]           — captured from the parent's scope;
#                              caller emits [r12 + 16 + slot*8] access
#                              (r12 = env_ptr, established by the
#                              prologue). slot indexes the parent's
#                              params-then-locals in declaration order.
#   ["global", null]         — fall through to the globals table.
proc scope_offset(name) {
    if in_function == false { return ["global", 0] }
    alloc np := length(current_func_params)
    alloc i := 0
    loop i < np {
        if current_func_params[i] == name {
            return ["local", (np - 1 - i) * 8]
        }
        i := i + 1
    }
    alloc nl := length(current_func_locals)
    alloc j := 0
    loop j < nl {
        if current_func_locals[j] == name {
            return ["local", -1 * (j + 1) * 8]
        }
        j := j + 1
    }
    # Not in own scope — check the flat env layout (full ancestor
    # chain). Phase 6c: a function sees variables from EVERY enclosing
    # scope, not just the immediate parent. Slot index in the env is
    # the position in the flattened list.
    alloc el := env_layout_of(current_func_name)
    alloc ei := 0
    alloc en := length(el)
    loop ei < en {
        if el[ei] == name {
            return ["free", ei]
        }
        ei := ei + 1
    }
    return ["global", 0]
}

# Helper: find a function's parent (or "" if top-level).
proc parent_of(name) {
    alloc i := 0
    alloc n := length(func_parents)
    loop i < n {
        if func_parents[i][0] == name {
            return func_parents[i][1]
        }
        i := i + 1
    }
    return ""
}

# Helper: find a function's [params, locals] from func_scope_info.
proc scope_info_of(name) {
    alloc i := 0
    alloc n := length(func_scope_info)
    loop i < n {
        if func_scope_info[i][0] == name {
            return [func_scope_info[i][1], func_scope_info[i][2]]
        }
        i := i + 1
    }
    return false
}

# Compute env_layout for `name` from scratch: flatten ancestor chain
# of [params + locals] in outermost-first order. Used by the pre-pass.
proc env_layout_compute(name) {
    alloc parent := parent_of(name)
    if parent == "" { return [] }
    alloc psi := scope_info_of(parent)
    if psi == false { return [] }
    alloc grand := env_layout_compute(parent)
    return grand + psi[0] + psi[1]
}

# Helper: look up the precomputed env_layout for `name`.
proc env_layout_of(name) {
    alloc i := 0
    alloc n := length(func_env_layouts)
    loop i < n {
        if func_env_layouts[i][0] == name {
            return func_env_layouts[i][1]
        }
        i := i + 1
    }
    return []
}

# Pre-scan a function body's instruction range to collect locals (in
# declaration order). Both STORE_LOCAL and MAKE_FUNC declare locals in
# the current scope — MAKE_FUNC binds a closure value to a name, and
# inner-proc names are resolved as locals from the enclosing body.
proc collect_locals(code, start, end_idx) {
    alloc locals := []
    alloc i := start
    loop i < end_idx {
        alloc instr := code[i]
        alloc op := instr[0]
        alloc declares := op == "STORE_LOCAL" or op == "MAKE_FUNC"
        if declares {
            alloc nm := instr[1]
            alloc seen := false
            alloc k := 0
            alloc nk := length(locals)
            loop k < nk {
                if locals[k] == nm { seen := true }
                k := k + 1
            }
            if seen == false {
                locals := locals + [nm]
            }
        }
        i := i + 1
    }
    return locals
}

# `mov rax, [r14 + disp32]` — 7 bytes. Used to load params / locals.
proc x_mov_rax_r14_disp32(disp) {
    ob_bytes([73, 139, 134])           # 49 8b 86
    ob_u32(disp & 4294967295)
}

# `mov [r14 + disp32], rax` — 7 bytes.
proc x_mov_r14_disp32_rax(disp) {
    ob_bytes([73, 137, 134])           # 49 89 86
    ob_u32(disp & 4294967295)
}

# `lea r15, [r14 + disp32]` — 7 bytes. Used by Ret to release locals
# and args in one shot.
proc x_lea_r15_r14_disp32(disp) {
    ob_bytes([77, 141, 190])           # 4d 8d be
    ob_u32(disp & 4294967295)
}

# Native `push r14` — 2 bytes (REX.B + push).
proc x_native_push_r14() { ob_bytes([65, 86]) }

# Native `pop r14` — 2 bytes.
proc x_native_pop_r14() { ob_bytes([65, 94]) }

# `mov r14, r15` — 3 bytes.
proc x_mov_r14_r15() { ob_bytes([77, 137, 254]) }

# Function prologue. For nested functions (parent != ""), also push
# the caller's r12 and load r12 with the env_ptr unpacked from the
# closure. The closure is at [r14 + n_args*8] (it was pushed by the
# caller before the args via CALL_VALUE).
proc gen_func_prologue(n_locals, n_args, is_nested) {
    x_native_push_r14()
    x_mov_r14_r15()
    if is_nested {
        # push r12 — 41 54
        ob_bytes([65, 84])
        # mov r12, [r14 + n_args*8]  — 4d 8b a6 <disp32>
        # ModR/M: mod=10 (disp32), reg=100(r12+REX.R), rm=110(r14+REX.B) → 0xa6
        ob_bytes([77, 139, 166])
        ob_u32((n_args * 8) & 4294967295)
        # mov r12, [r12 + 16]  — 4d 8b 64 24 10
        # ModR/M: mod=01 (disp8), reg=100, rm=100 (SIB) → 0x64
        # SIB:    scale=00, index=100, base=100 → 0x24
        # disp8 = 16
        ob_bytes([77, 139, 100, 36, 16])
    }
    if n_locals > 0 {
        # sub r15, imm32 — 49 81 ef <imm32>
        ob_bytes([73, 129, 239])
        ob_u32((n_locals * 8) & 4294967295)
    }
}

# Function epilogue. is_nested mirrors the prologue: if set, pop the
# saved r12 before pop r14.
proc gen_func_epilogue(n_args, is_nested) {
    # rax = [r15]  (top of operand stack = return value)
    ob_bytes([73, 139, 7])
    # lea r15, [r14 + (n_args-1)*8]
    x_lea_r15_r14_disp32((n_args - 1) * 8)
    # [r15] = rax
    ob_bytes([73, 137, 7])
    if is_nested {
        # pop r12 — 41 5c
        ob_bytes([65, 92])
    }
    x_native_pop_r14()
    ob_byte(195)                                          # ret
}

proc gen_call(name) {
    alloc site := x_call_rel32_patchable()
    fn_call_patches := fn_call_patches + [[site, name]]
}

# TCALL = direct tail call. Semantically: the call's return value IS
# our function's return value. The OMG compiler emits a defensive
# PushNone + Ret after the TCALL that NEVER executes in the VM (TCALL
# transfers control to the callee, which returns to OUR caller).
#
# Phase 4 implements this as call + ret: the call leaves its result on
# top of the operand stack, then we immediately run the epilogue which
# returns that value to our caller. No actual tail-call optimisation
# yet — the native stack still grows one frame per recursion. Real TCO
# (deallocate our frame, JMP instead of CALL so callee's RET targets
# our caller) is a phase-11 concern. The dead bytes for the trailing
# PushNone + Ret never run since we ret'd above them.
proc gen_tcall(name) {
    gen_call(name)
    gen_ret()
}

# MAKE_FUNC(name): construct a closure value and store it into the
# slot for `name`. Closure layout: [type=3, func_addr, env_ptr]. 24 bytes.
#
# At the top level, env_ptr=0 — the inner function has no enclosing
# scope to capture from. Inside a function body, we additionally
# allocate an env snapshot containing the enclosing function's
# params + locals (in declaration order), and set env_ptr to point
# at it. The inner function's prologue loads this env into r12 and
# free-variable references in its body access slots via
# [r12 + 16 + slot*8] (env header is [type=4, nslots]).
#
# Phase 6b uses SNAPSHOT semantics: the env captures values at
# MAKE_FUNC time. Mutations in the enclosing scope after the closure
# is created don't propagate to the closure — that's by-reference
# capture (phase 6c) and needs boxed locals.
proc gen_make_func(name) {
    # First: if we're inside a function body, allocate the env and
    # populate it from current_func_params + current_func_locals.
    # The result lives in r10 (a scratch register we preserve through
    # the closure alloc that follows by saving on the native stack).
    alloc has_env := in_function
    if has_env {
        # Inner's env layout = (current's env layout) + (current's
        # params) + (current's locals). The first `parent_env_size`
        # slots are copied verbatim from r12 (current's env). The
        # next slots are copied from r14-relative frame positions.
        alloc parent_env := env_layout_of(current_func_name)
        alloc parent_env_size := length(parent_env)
        alloc np := length(current_func_params)
        alloc nl := length(current_func_locals)
        alloc nslots := parent_env_size + np + nl
        # rt_alloc(16 + nslots*8)
        x_mov_imm32(REG_RAX, 16 + nslots * 8)
        alloc se_alloc := x_call_rel32_patchable()
        patch_call_rel32(se_alloc, rt_alloc_off)
        # mov qword [rax], 4 — env type tag
        ob_bytes([72, 199, 0, 4, 0, 0, 0])
        # mov qword [rax + 8], nslots
        ob_bytes([72, 199, 64, 8])
        ob_u32(nslots & 4294967295)
        # Copy `parent_env_size` slots from r12 (current env) into the
        # new env's first slots. Phase 6c: this is what carries the
        # grandparent (and further-up) variables into the child's env.
        alloc pi := 0
        loop pi < parent_env_size {
            # rcx = [r12 + 16 + pi*8]  — 49 8b 8c 24 <disp32>
            # ModR/M: mod=10, reg=001(rcx), rm=100 (SIB) → 0x8c
            # SIB:    scale=00, index=100 (no index), base=100 (r12+B) → 0x24
            ob_bytes([73, 139, 140, 36])
            ob_u32((16 + pi * 8) & 4294967295)
            # [rax + 16 + pi*8] = rcx
            ob_bytes([72, 137, 136])
            ob_u32((16 + pi * 8) & 4294967295)
            pi := pi + 1
        }
        # Copy current function's params into env slots
        # [parent_env_size, parent_env_size+np).
        alloc i := 0
        loop i < np {
            # rcx = [r14 + (np-1-i)*8]
            ob_bytes([73, 139, 142])
            ob_u32(((np - 1 - i) * 8) & 4294967295)
            # [rax + 16 + (parent_env_size + i)*8] = rcx
            ob_bytes([72, 137, 136])
            ob_u32((16 + (parent_env_size + i) * 8) & 4294967295)
            i := i + 1
        }
        # Copy current function's locals into the remaining slots.
        alloc j := 0
        loop j < nl {
            ob_bytes([73, 139, 142])
            ob_u32(((-1 * (j + 1) * 8)) & 4294967295)
            ob_bytes([72, 137, 136])
            ob_u32((16 + (parent_env_size + np + j) * 8) & 4294967295)
            j := j + 1
        }
        # Save env ptr while we allocate the closure object.
        ob_byte(80)                          # push rax
    }
    # Allocate the closure (24 bytes).
    x_mov_imm32(REG_RAX, 24)
    alloc s_alloc := x_call_rel32_patchable()
    patch_call_rel32(s_alloc, rt_alloc_off)
    # type=3
    ob_bytes([72, 199, 0, 3, 0, 0, 0])
    # func_addr at [rax+8] — patched after all bodies are emitted.
    ob_bytes([72, 185])
    alloc fn_imm_site := ob_top
    ob_u64(0)
    fn_closure_patches := fn_closure_patches + [[fn_imm_site, name]]
    ob_bytes([72, 137, 72, 8])
    # env_ptr at [rax+16]: either 0 (top-level) or the env we just
    # allocated (saved on the native stack).
    if has_env {
        # pop rcx — 59 (recover env ptr saved earlier)
        ob_byte(89)
        # mov [rax + 16], rcx — 48 89 48 10
        ob_bytes([72, 137, 72, 16])
    } else {
        ob_bytes([72, 199, 64, 16, 0, 0, 0, 0])
    }
    gen_store_rax(name)
}

# CALL_VALUE(argc): the operand stack has [..., closure, arg_1, ...,
# arg_N] with arg_N on top. Pull func_addr from the closure (which
# sits at [r15 + argc*8]), native-call it, then collapse the closure
# slot so the post-return stack ends with the return value at the
# closure's old position.
proc gen_call_value(argc) {
    # mov rcx, [r15 + argc*8] — 49 8b 8f <disp32>
    ob_bytes([73, 139, 143])
    ob_u32((argc * 8) & 4294967295)
    # mov rax, [rcx + 8] (func_addr; offset 8 in the closure object)
    # 48 8b 41 08
    ob_bytes([72, 139, 65, 8])
    # call rax — ff d0
    ob_bytes([255, 208])
    # Cleanup: at this point r15 = r14_at_call + (N-1)*8 (function
    # epilogue's lea result), with the return value at [r15] and the
    # stale closure slot at [r15 + 8]. We need to overwrite the
    # closure slot with the return value and bump r15 by 8.
    # mov rax, [r15] — 49 8b 07
    ob_bytes([73, 139, 7])
    # add r15, 8 — 49 83 c7 08
    ob_bytes([73, 131, 199, 8])
    # mov [r15], rax — 49 89 07
    ob_bytes([73, 137, 7])
}

# === Phase 5 — heap values =============================================

# BUILD_LIST(N): rt_build_list pops N elements from the operand stack
# and returns a tagged list pointer in rax. Push it onto the operand
# stack to make it available to subsequent ops.
proc gen_build_list(n) {
    x_mov_imm32(REG_RAX, n)
    alloc site := x_call_rel32_patchable()
    patch_call_rel32(site, rt_build_list_off)
    x_push_reg(REG_RAX)
}

# INDEX: pop key, pop container, dispatch by container's type tag.
# rt_index handles list (tagged-int key) vs dict (string-pointer key).
proc gen_index() {
    x_pop_reg(REG_RBX)                            # key (raw, tag untouched)
    x_pop_reg(REG_RAX)                            # container ptr
    alloc site := x_call_rel32_patchable()
    patch_call_rel32(site, rt_index_off)
    x_push_reg(REG_RAX)                           # result
}

# STORE_INDEX: stack is [..., container, key, value]. Dispatches by
# container type via rt_store_index. List path is in-place; dict path
# may grow but the user-visible pointer doesn't change (phase 5e).
proc gen_store_index() {
    x_pop_reg(REG_RDX)                            # value
    x_pop_reg(REG_RBX)                            # key
    x_pop_reg(REG_RAX)                            # container ptr
    alloc site := x_call_rel32_patchable()
    patch_call_rel32(site, rt_store_index_off)
}

# BUILD_DICT(N): pops 2N values (N key-value pairs) and pushes a new
# dict pointer.
proc gen_build_dict(n) {
    x_mov_imm32(REG_RAX, n)
    alloc site := x_call_rel32_patchable()
    patch_call_rel32(site, rt_build_dict_off)
    x_push_reg(REG_RAX)
}

# SLICE: stack is [..., container, start, end]. Allocates a new
# container of the same type holding elements [start, end). Calls
# rt_slice which dispatches by the type tag at [container].
proc gen_slice() {
    x_pop_reg(REG_RCX)                            # tagged end
    x_pop_reg(REG_RBX)                            # tagged start
    x_pop_reg(REG_RAX)                            # container pointer
    alloc site := x_call_rel32_patchable()
    patch_call_rel32(site, rt_slice_off)
    x_push_reg(REG_RAX)
}

# POP discards the top of the operand stack. Used after a Call whose
# return value isn't consumed (statement-context calls).
proc gen_pop() {
    # add r15, 8 — drops the top slot without reading it
    ob_bytes([73, 131, 199, 8])
}

# === Phase 7 — exception codegen ========================================

# SETUP_EXCEPT(target_idx): push a handler record onto the exception
# stack. Records (handler_machine_addr, r15, r14, r12, rsp) so RAISE
# can unwind to here. The handler address is patched after all bodies
# are emitted via setup_except_patches.
alloc setup_except_patches := []     # list of [imm64_site, target_bytecode_idx]

proc gen_setup_except(target_idx) {
    # mov rax, imm64 (handler_addr placeholder) — 48 b8 <imm64>
    ob_bytes([72, 184])
    alloc imm_site := ob_top
    ob_u64(0)
    setup_except_patches := setup_except_patches + [[imm_site, target_idx]]
    # call rt_setup_except — rax in, no result
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_setup_except_off)
}

# POP_BLOCK: discard the top handler record (the try block completed
# without raising). The compiler also emits POP_BLOCK before any
# control transfer that crosses out of a try (RET, BREAK, JUMP out of
# a loop containing a try), so this is the universal unwind primitive.
proc gen_pop_block() {
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_pop_block_off)
}

# RAISE(kind): pop the exception value off the operand stack, then
# unwind via the top handler. The kind argument (TypeError, ValueError,
# etc.) is ignored in phase 7 — handlers don't dispatch by kind yet;
# they just catch whatever's raised. Phase 8 may add typed except.
proc gen_raise(kind) {
    x_pop_reg(REG_RAX)
    alloc s := x_call_rel32_patchable()
    patch_call_rel32(s, rt_raise_off)
}

# BUILTIN(name, argc). Phase 5a only handles `length`, which works for
# both strings and lists thanks to their shared `length at offset 8`
# layout. Other builtins panic — we add them in 5b/5c as needed.
proc gen_builtin(name, argc) {
    if name == "length" {
        if argc != 1 { panic("native-asm: length() expects 1 arg, got " + argc) }
        x_pop_reg(REG_RAX)
        ob_bytes([72, 139, 64, 8])                  # mov rax, [rax + 8]
        x_sal_rax_1()
        x_or_rax_imm8(1)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "ascii" {
        # Pop a 1-char string, push its byte tagged as int.
        x_pop_reg(REG_RAX)
        # movzx rax, byte [rax + 16] — 48 0f b6 40 10
        ob_bytes([72, 15, 182, 64, 16])
        x_sal_rax_1()
        x_or_rax_imm8(1)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "chr" {
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_chr_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "exit" {
        # Pop a tagged int, call sys_exit. Never returns.
        x_pop_reg(REG_RAX)
        x_sar_rax_1()
        # mov rdi, rax — 48 89 c7
        ob_bytes([72, 137, 199])
        x_mov_imm32(REG_RAX, 60)
        x_syscall()
        # Unreachable, but the bytecode treats CallBuiltin as an
        # expression and expects something on the stack. Emit a
        # placeholder push to keep the operand stack balanced for
        # any code that comes after (it'll never run, but the
        # codegen invariants stay clean).
        x_mov_imm32(REG_RAX, TAG_NONE)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "freeze" {
        # No-op: pass through the dict pointer unchanged.
        return false
    }
    if name == "print" {
        # Same as EMIT but no trailing newline. Pop value, call the
        # repr dispatcher (which writes the textual representation
        # without a newline), push TAG_NONE as the expression value.
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_emit_dispatch_repr_off)
        x_mov_imm32(REG_RAX, TAG_NONE)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "list_repeat" {
        # Stack has [item, count] with count on top.
        x_pop_reg(REG_RCX)                          # tagged count
        # sar rcx, 1 — 48 d1 f9
        ob_bytes([72, 209, 249])
        x_pop_reg(REG_RAX)                          # item (kept tagged)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_list_repeat_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "dict_keys" {
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_dict_keys_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "bytes_to_string" {
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_bytes_to_string_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "string_bytes" {
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_string_bytes_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "int" {
        # OMG's int(s) parses a string. Phase 8 only handles strings;
        # int(int) and int(float) panic.
        x_pop_reg(REG_RAX)
        alloc s := x_call_rel32_patchable()
        patch_call_rel32(s, rt_str_to_int_off)
        x_push_reg(REG_RAX)
        return false
    }
    if name == "getpid" {
        # syscall 39 — getpid. Returns pid in rax.
        x_mov_imm32(REG_RAX, 39)
        x_syscall()
        x_sal_rax_1()
        x_or_rax_imm8(1)
        x_push_reg(REG_RAX)
        return false
    }
    panic("native-asm: builtin '" + name + "' not yet implemented")
}

# RET emits the function epilogue + native ret. Uses the current
# function's param count for the operand-stack restoration.
proc gen_ret() {
    if in_function == false {
        panic("native-asm: RET emitted at top level (unexpected)")
    }
    alloc is_nested := current_parent_name != ""
    gen_func_epilogue(length(current_func_params), is_nested)
}

# === Globals ============================================================
# Each unique name referenced by LOAD/STORE/STORE_LOCAL gets a slot in
# a globals memory area allocated at the end of the ELF. The slot
# table maps name → 0-based index; globals_base_vaddr + slot*8 is the
# address of the 8-byte value. We pre-scan the bytecode to determine
# the set of names (so the area's size is known when we finalise the
# ELF), then LOAD/STORE codegen emits `mov rax, [imm32]` style
# absolute references.

alloc globals_table := []   # list of [name, slot]. linear search; small N.

proc globals_slot(name) {
    alloc i := 0
    alloc n := length(globals_table)
    loop i < n {
        if globals_table[i][0] == name {
            return globals_table[i][1]
        }
        i := i + 1
    }
    alloc slot := length(globals_table)
    globals_table := globals_table + [[name, slot]]
    return slot
}

# Address (virtual) of slot `i`. Filled in once layout is finalised
# (after we know how many slots there are and the data tail position).
# For now we use a placeholder and patch it during finalize_elf.
alloc globals_base_vaddr := 0
alloc globals_addr_patches := []  # list of [patch_site, slot_index]

# LOAD/STORE/STORE_LOCAL: resolve `name` in the current scope. Inside a
# function body, params and locals live at known offsets from r14;
# fall through to the globals table when no local binding matches.

proc gen_load(name) {
    alloc r := scope_offset(name)
    alloc kind := r[0]
    if kind == "local" {
        x_mov_rax_r14_disp32(r[1])
        x_push_reg(REG_RAX)
        return false
    }
    if kind == "free" {
        # mov rax, [r12 + 16 + slot*8] — 49 8b 84 24 <disp32>
        # ModR/M: mod=10 (disp32), reg=000(rax), rm=100 (SIB) → 0x84
        # SIB:    scale=00 (×1), index=100 (no idx), base=100 (r12+REX.B) → 0x24
        # disp32 = 16 + slot*8
        ob_bytes([73, 139, 132, 36])
        ob_u32((16 + r[1] * 8) & 4294967295)
        x_push_reg(REG_RAX)
        return false
    }
    alloc slot := globals_slot(name)
    ob_byte(72)
    ob_byte(184 + REG_RCX)
    alloc site := ob_top
    ob_u64(0)
    globals_addr_patches := globals_addr_patches + [[site, slot, "load"]]
    x_mov_rax_mem_rcx()
    x_push_reg(REG_RAX)
}

proc gen_store(name) {
    x_pop_reg(REG_RAX)
    gen_store_rax(name)
}

# Helper: store rax into the slot for `name` without first popping.
# Used by both STORE/STORE_LOCAL (caller pops first) and MAKE_FUNC
# (closure pointer is freshly produced by rt_alloc into rax).
proc gen_store_rax(name) {
    alloc r := scope_offset(name)
    alloc kind := r[0]
    if kind == "local" {
        x_mov_r14_disp32_rax(r[1])
        return false
    }
    if kind == "free" {
        # mov [r12 + 16 + slot*8], rax — 49 89 84 24 <disp32>
        ob_bytes([73, 137, 132, 36])
        ob_u32((16 + r[1] * 8) & 4294967295)
        return false
    }
    alloc slot := globals_slot(name)
    ob_byte(72)
    ob_byte(184 + REG_RCX)
    alloc site := ob_top
    ob_u64(0)
    globals_addr_patches := globals_addr_patches + [[site, slot, "store"]]
    x_mov_mem_rcx_rax()
}

# Emit one instruction's machine code. Records the instruction's
# starting ob_buf offset in instr_offsets[bytecode_idx] so later jump
# patches can translate target indices to machine offsets.
proc gen_one(instr, bytecode_idx, dispatch_off) {
    instr_offsets[bytecode_idx] := ob_top
    alloc op := instr[0]
    if op == "PUSH_INT" { gen_push_int(instr[1]) } else {
    if op == "PUSH_FLOAT" { gen_push_float(instr[1]) } else {
    if op == "PUSH_STR" { gen_push_str(instr[1]) } else {
    if op == "PUSH_BOOL"{ gen_push_bool(instr[1]) }else {
    if op == "PUSH_NONE"{ gen_push_none() }        else {
    if op == "ADD"      { gen_add() }              else {
    if op == "SUB"      { gen_sub() }              else {
    if op == "MUL"      { gen_mul() }              else {
    if op == "DIV"      { gen_div() }              else {
    if op == "MOD"      { gen_mod() }              else {
    if op == "NEG"      { gen_neg() }              else {
    if op == "NOT"      { gen_not() }              else {
    if op == "EQ"       { gen_eq() }               else {
    if op == "NE"       { gen_ne() }               else {
    if op == "LT"       { gen_lt() }               else {
    if op == "LE"       { gen_le() }               else {
    if op == "GT"       { gen_gt() }               else {
    if op == "GE"       { gen_ge() }               else {
    if op == "JUMP"     { gen_jump(instr[1]) }     else {
    if op == "JUMP_IF_FALSE" { gen_jump_if_false(instr[1]) } else {
    if op == "LOAD"     { gen_load(instr[1]) }     else {
    if op == "STORE"    { gen_store(instr[1]) }    else {
    if op == "STORE_LOCAL" { gen_store(instr[1]) } else {
    if op == "CALL"     { gen_call(instr[1]) }     else {
    if op == "TCALL"    { gen_tcall(instr[1]) }    else {
    if op == "CALL_VALUE" { gen_call_value(instr[1]) } else {
    if op == "MAKE_FUNC"{ gen_make_func(instr[1]) }else {
    if op == "RET"      { gen_ret() }              else {
    if op == "BUILD_LIST"{ gen_build_list(instr[1]) } else {
    if op == "BUILD_DICT"{ gen_build_dict(instr[1]) } else {
    if op == "INDEX"    { gen_index() }            else {
    if op == "SLICE"    { gen_slice() }            else {
    if op == "STORE_INDEX" { gen_store_index() }   else {
    if op == "BUILTIN"  { gen_builtin(instr[1][0], instr[1][1]) } else {
    if op == "POP"      { gen_pop() }              else {
    if op == "POP_BLOCK"   { gen_pop_block() }     else {
    if op == "SETUP_EXCEPT"{ gen_setup_except(instr[1]) } else {
    if op == "RAISE"    { gen_raise(instr[1]) }    else {
    if op == "EMIT"     { gen_emit(dispatch_off) } else {
    if op == "HALT"     { gen_halt() }             else {
        panic("native-asm: unsupported op " + op)
    }}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}
}

# Pre-pass: build func_scope_info (params + locals per function) and
# func_parents (which function declared each via MAKE_FUNC, or "" if
# top-level). This lets us resolve free-variable references at
# codegen time even when an inner function appears BEFORE its parent
# in the bytecode (which is the typical case — functions are listed
# in declaration order, and inner procs are declared before the body
# that contains them gets fully emitted).
proc compute_func_scopes(code, funcs, top_level_end) {
    func_scope_info := []
    func_parents := []
    alloc total := length(code)
    # Pass 1: scope info per function.
    alloc fi := 0
    alloc fn := length(funcs)
    loop fi < fn {
        alloc f := funcs[fi]
        alloc fname := f[0]
        alloc params := f[1]
        alloc start := f[2]
        alloc end_idx := total
        alloc j := 0
        loop j < fn {
            if funcs[j][2] > start and funcs[j][2] < end_idx {
                end_idx := funcs[j][2]
            }
            j := j + 1
        }
        alloc locals := collect_locals(code, start, end_idx)
        func_scope_info := func_scope_info + [[fname, params, locals, start, end_idx]]
        fi := fi + 1
    }
    # Pass 2: parent assignments. Top-level MAKE_FUNCs declare
    # top-level procs (parent = ""). MAKE_FUNCs inside a function
    # body declare nested procs (parent = enclosing function name).
    alloc k := 0
    loop k < top_level_end {
        if code[k][0] == "MAKE_FUNC" {
            func_parents := func_parents + [[code[k][1], ""]]
        }
        k := k + 1
    }
    fi := 0
    loop fi < length(func_scope_info) {
        alloc fsi := func_scope_info[fi]
        alloc fname := fsi[0]
        alloc start := fsi[3]
        alloc end_idx := fsi[4]
        k := start
        loop k < end_idx {
            if code[k][0] == "MAKE_FUNC" {
                func_parents := func_parents + [[code[k][1], fname]]
            }
            k := k + 1
        }
        fi := fi + 1
    }
    # Pass 3: precompute the flat env_layout for each function.
    # Needs parent + scope_info to be already populated.
    func_env_layouts := []
    fi := 0
    loop fi < length(func_scope_info) {
        alloc fname := func_scope_info[fi][0]
        func_env_layouts := func_env_layouts + [[fname, env_layout_compute(fname)]]
        fi := fi + 1
    }
}

# Emit the top-level code (instructions [0, top_level_end)) plus each
# function body. Records each function's machine entry in fn_entry,
# pre-allocates instr_offsets so jump patches inside any region can be
# resolved.
proc gen_code(code, funcs, dispatch_off) {
    alloc total := length(code)
    instr_offsets := list_repeat(0, total + 1)
    alloc top_level_end := total
    alloc fi := 0
    alloc fn := length(funcs)
    loop fi < fn {
        if funcs[fi][2] < top_level_end {
            top_level_end := funcs[fi][2]
        }
        fi := fi + 1
    }
    # Pre-pass: build scope info + parent map so free-variable
    # resolution works for inner functions emitted later.
    compute_func_scopes(code, funcs, top_level_end)
    # === Top-level (scope = globals) ===
    in_function := false
    current_func_params := []
    current_func_locals := []
    current_func_name := ""
    current_parent_name := ""
    alloc i := 0
    loop i < top_level_end {
        gen_one(code[i], i, dispatch_off)
        i := i + 1
    }
    # === Each function body ===
    fi := 0
    loop fi < fn {
        alloc fdef := funcs[fi]
        alloc fname := fdef[0]
        alloc params := fdef[1]
        alloc start := fdef[2]
        alloc end_idx := total
        alloc j := 0
        loop j < fn {
            if funcs[j][2] > start and funcs[j][2] < end_idx {
                end_idx := funcs[j][2]
            }
            j := j + 1
        }
        alloc locals := collect_locals(code, start, end_idx)
        fn_entry_set(fname, ob_top)
        in_function := true
        current_func_params := params
        current_func_locals := locals
        current_func_name := fname
        current_parent_name := parent_of(fname)
        alloc is_nested := current_parent_name != ""
        gen_func_prologue(length(locals), length(params), is_nested)
        alloc k := start
        loop k < end_idx {
            gen_one(code[k], k, dispatch_off)
            k := k + 1
        }
        in_function := false
        current_func_params := []
        current_func_locals := []
        current_func_name := ""
        current_parent_name := ""
        fi := fi + 1
    }
    instr_offsets[total] := ob_top
}

# === Final assembly =======================================================
# After all code is emitted, append the string-header data:
#   header  := [u64 length, bytes..., (padding to 8 bytes)]
# We pad each header to 8 bytes so the next header's start is also
# 8-aligned. The first header's address has LSB=0 (which is the tag
# convention for "this is a pointer"), and our 8-alignment ensures
# every subsequent header keeps that property.

proc pad_to_8() {
    loop (ob_top & 7) != 0 {
        ob_byte(0)
    }
}

proc finalize_elf(entry_vaddr, r15_init_site, r13_init_site) {
    # 1. Resolve jump patches now that every instruction's machine
    # offset is known via instr_offsets.
    alloc j := 0
    alloc jn := length(jump_patches)
    loop j < jn {
        alloc jp := jump_patches[j]
        alloc target_idx := jp[1]
        if target_idx >= length(instr_offsets) {
            panic("native-asm: jump target out of range")
        }
        patch_rel32(jp[0], instr_offsets[target_idx])
        j := j + 1
    }
    # 2. EMIT call sites — payload-relative; safe to patch directly.
    alloc c := 0
    alloc cn := length(emit_call_sites)
    loop c < cn {
        alloc cs := emit_call_sites[c]
        patch_call_rel32(cs[0], cs[1])
        c := c + 1
    }
    # 2b. Direct-call sites (Call("name") / TCall("name")). Each was
    # emitted as a 5-byte `call rel32 0` placeholder; patch the rel32
    # to the function's machine entry recorded in fn_entry.
    alloc fc := 0
    alloc fcn := length(fn_call_patches)
    loop fc < fcn {
        alloc fp := fn_call_patches[fc]
        patch_call_rel32(fp[0], fn_entry_get(fp[1]))
        fc := fc + 1
    }
    # 2bb. SETUP_EXCEPT handler-address patches: each setup site
    # carries an imm64 placeholder for the handler's machine address,
    # which is the bytecode-index-to-machine-offset translation we
    # already have via instr_offsets.
    alloc sep := 0
    alloc sepn := length(setup_except_patches)
    loop sep < sepn {
        alloc spat := setup_except_patches[sep]
        alloc target_idx := spat[1]
        alloc handler_vaddr := ELF_BASE + HEADERS_SIZE + instr_offsets[target_idx]
        patch_u64(spat[0], handler_vaddr)
        sep := sep + 1
    }
    # 2c. MAKE_FUNC closure patches: each closure carries the absolute
    # virtual address of the function's machine entry. The address is
    # ELF_BASE + HEADERS_SIZE + fn_entry_offset_in_payload.
    alloc mp := 0
    alloc mpn := length(fn_closure_patches)
    loop mp < mpn {
        alloc cp := fn_closure_patches[mp]
        # Note: NOT named `entry_vaddr` to avoid shadowing the param
        # of the same name. OMG's `alloc` introduces a name into the
        # enclosing proc scope, so a clash here would clobber the
        # parameter for everything after the loop, including the
        # subsequent `write_u64_into(h, 24, entry_vaddr)`.
        alloc fn_vaddr := ELF_BASE + HEADERS_SIZE + fn_entry_get(cp[1])
        patch_u64(cp[0], fn_vaddr)
        mp := mp + 1
    }
    # 3. Layout string-header data right after code, recording each
    # header's absolute virtual address. Layout matches the runtime
    # heap-object shape so the EMIT dispatcher can treat static
    # strings and heap-allocated strings uniformly: [type=0, length,
    # bytes...]. The pointer-to-header ends up tagged as 8-aligned
    # (LSB=0) so it's distinguishable from int / sentinel values.
    pad_to_8()
    alloc i := 0
    alloc n := length(deferred_strings)
    loop i < n {
        alloc ds := deferred_strings[i]
        alloc s := ds[0]
        alloc site := ds[1]
        alloc header_vaddr := ELF_BASE + HEADERS_SIZE + ob_top
        ob_u64(HEAP_T_STRING)
        ob_u64(length(s))
        ob_string_bytes(s)
        pad_to_8()
        patch_u64(site, header_vaddr)
        i := i + 1
    }
    # 4. Layout the globals area: 8 bytes per slot, zero-initialised
    # (every slot is set to tagged-zero, which represents "uninitialised
    # int 0"). The vaddr of slot 0 is fixed now; patch every LOAD/STORE
    # site with the right per-slot address.
    pad_to_8()
    globals_base_vaddr := ELF_BASE + HEADERS_SIZE + ob_top
    alloc g := 0
    alloc gn := length(globals_table)
    loop g < gn {
        # Tagged zero = `(0 << 1) | 1 = 1`. We use the tagged
        # representation so an unwritten LOAD that hits this slot
        # produces a valid (if surprising) `0` rather than a value
        # the dispatcher would mis-classify.
        ob_u64(1)
        g := g + 1
    }
    # Patch every LOAD/STORE imm64 with its slot's absolute address.
    alloc gp := 0
    alloc gpn := length(globals_addr_patches)
    loop gp < gpn {
        alloc gap := globals_addr_patches[gp]
        alloc slot_addr := globals_base_vaddr + gap[1] * 8
        patch_u64(gap[0], slot_addr)
        gp := gp + 1
    }
    alloc payload_size := ob_top
    alloc file_size := payload_size + HEADERS_SIZE
    # 4b. Heap + operand-stack + except-stack regions: live in memory
    # but NOT in the file. `p_memsz = p_filesz + HEAP_SIZE +
    # OPERAND_STACK_SIZE + EXCEPT_STACK_SIZE` tells the kernel to
    # zero-fill those slabs at the high end of the mapped segment.
    #
    # Layout (low → high):
    #   [file contents] [heap (1MB, grow-up)] [op stack (64KB, grow-down)] [except stack (8KB, grow-up)]
    #   ^ ELF_BASE     ^ heap_base            ^ op_base ─→ stack_top      ^ except_base
    #
    # The first 8 bytes of the heap region are RESERVED for the
    # except_top slot — a single u64 holding the address of the next
    # free byte of the exception-handler stack. r13 initialises to
    # heap_base + 8 so user allocations don't overwrite it. r15
    # initialises to stack_top.
    alloc heap_base   := ELF_BASE + file_size
    alloc except_top_slot_vaddr := heap_base
    alloc bump_base   := heap_base + 8
    alloc op_base     := heap_base + HEAP_SIZE
    alloc stack_top   := op_base + OPERAND_STACK_SIZE
    alloc except_base := stack_top
    alloc mem_size    := file_size + HEAP_SIZE + OPERAND_STACK_SIZE + EXCEPT_STACK_SIZE
    patch_u64(r15_init_site, stack_top)
    patch_u64(r13_init_site, bump_base)
    patch_u64(except_init_slot_site, except_top_slot_vaddr)
    patch_u64(except_init_base_site, except_base)
    # Patch every except helper's `mov rcx, imm64 (slot_addr)` site.
    alloc esi := 0
    alloc esn := length(except_slot_patch_sites)
    loop esi < esn {
        patch_u64(except_slot_patch_sites[esi], except_top_slot_vaddr)
        esi := esi + 1
    }
    # 5. Build ELF header + program header. Segment is R+W+X so the
    # globals area is writable — splitting into separate R+X / R+W
    # segments is a phase-10 cleanup.
    alloc h := list_repeat(0, HEADERS_SIZE)
    h[0] := 127
    h[1] := ascii("E")
    h[2] := ascii("L")
    h[3] := ascii("F")
    h[4] := 2
    h[5] := 1
    h[6] := 1
    h[7] := 0
    h[16] := 2
    h[18] := 62
    h[20] := 1
    write_u64_into(h, 24, entry_vaddr)            # e_entry
    write_u64_into(h, 32, ELF_HEADER_SIZE)        # e_phoff
    h[52] := 64
    h[54] := 56
    h[56] := 1
    alloc p := ELF_HEADER_SIZE
    h[p]     := 1                                 # p_type = PT_LOAD
    h[p + 4] := 7                                 # p_flags = PF_R | PF_W | PF_X
    write_u64_into(h, p + 16, ELF_BASE)
    write_u64_into(h, p + 24, ELF_BASE)
    write_u64_into(h, p + 32, file_size)
    write_u64_into(h, p + 40, mem_size)     # p_memsz > p_filesz → zero-filled tail
    h[p + 48] := 0
    h[p + 49] := 16
    return h + ob_buf[0:payload_size]
}

proc patch_u64(offset, n) {
    alloc x := n
    alloc i := 0
    loop i < 8 {
        ob_buf[offset + i] := x & 255
        x := x >> 8
        i := i + 1
    }
}

proc write_u64_into(buf, offset, n) {
    alloc x := n
    alloc i := 0
    loop i < 8 {
        buf[offset + i] := x & 255
        x := x >> 8
        i := i + 1
    }
}

# === Entry point ==========================================================

proc main_compile() {
    if length(args) < 3 {
        emit "usage: omgna <in.omgb> <out>"
        emit "  Phase 2: PUSH_INT, PUSH_STR, ADD, SUB, MUL, DIV, MOD, NEG, EMIT, HALT"
        exit(1)
    }
    alloc in_path := args[1]
    alloc out_path := args[2]
    alloc fh := file_open(in_path, "rb")
    if fh == false { panic("cannot read '" + in_path + "'") }
    alloc raw := file_read(fh)
    file_close(fh)
    alloc parsed := parse_bytecode(raw)
    alloc code := parsed[0]
    alloc funcs := parsed[1]
    ob_reset()
    deferred_strings := []
    emit_call_sites := []
    jump_patches := []
    instr_offsets := []
    globals_table := []
    globals_addr_patches := []
    # 1. Emit the runtime blob first; record dispatcher offset.
    alloc dispatch_off := emit_runtime_blob()
    # 2. Record where user code (and thus the ELF entry point) starts.
    alloc user_entry := ob_top
    # 3. Emit prologue: load r15 with the operand-stack top, r13 with
    # the heap bump pointer, and seed the `except_top` slot with the
    # base of the exception-handler stack. All four imm64s get patched
    # in finalize_elf once heap/stack/except layout is finalised.
    alloc r15_init_site := x_mov_r15_imm64_patchable()
    alloc r13_init_site := x_mov_r13_imm64_patchable()
    # mov rcx, imm64 (except_top_slot_vaddr) — 48 b9 <imm64>
    ob_bytes([72, 185])
    except_init_slot_site := ob_top
    ob_u64(0)
    # mov rax, imm64 (except_base) — 48 b8 <imm64>
    ob_bytes([72, 184])
    except_init_base_site := ob_top
    ob_u64(0)
    # mov [rcx], rax — 48 89 01
    ob_bytes([72, 137, 1])
    # 4. Emit user code (top-level + each function body).
    fn_entry := []
    fn_call_patches := []
    fn_closure_patches := []
    setup_except_patches := []
    gen_code(code, funcs, dispatch_off)
    # 5. Finalize layout, resolve all patches, prepend headers.
    alloc elf_bytes := finalize_elf(ELF_BASE + HEADERS_SIZE + user_entry, r15_init_site, r13_init_site)
    alloc oh := file_open(out_path, "wb")
    file_write(oh, elf_bytes)
    file_close(oh)
    subprocess(["chmod", "755", out_path])
}

main_compile()
