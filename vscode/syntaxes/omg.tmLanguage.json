{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.omg",
  "name": "OMG Language",
  "fileTypes": ["omg"],
  "patterns": [
    { "include": "#header" },
    { "include": "#comments" },
    { "include": "#import-statements" },
    { "include": "#function-definitions" },
    { "include": "#namespace-access" },
    { "include": "#function-calls" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "header": {
      "patterns": [
        {
          "name": "comment.line.header.omg",
          "match": "^\\s*;;;omg\\s*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.omg",
          "match": "#.*$"
        },
        {
          "name": "comment.block.documentation.omg",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "keyword.tag.docblock.omg",
              "match": "@(param|return|module|version|throws|deprecated)\\b"
            }
          ]
        },
        {
          "name": "comment.block.omg",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "import-statements": {
      "patterns": [
        {
          "name": "meta.import.omg",
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.omg" }
          },
          "end": "$",
          "patterns": [
            {
              "name": "string.quoted.path.omg",
              "begin": "\"",
              "end": "\"",
              "patterns": [
                { "match": "\\\\.", "name": "constant.character.escape.omg" }
              ]
            },
            {
              "name": "keyword.control.as.omg",
              "match": "\\bas\\b"
            },
            {
              "name": "entity.name.namespace.omg",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "namespace-access": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\.[A-Za-z_])",
          "captures": {
            "1": { "name": "entity.name.namespace.omg" }
          }
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "name": "meta.function.definition.omg",
          "begin": "\\b(proc)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "keyword.control.omg storage.type.function.omg" },
            "2": { "name": "entity.name.function.omg" },
            "3": { "name": "punctuation.definition.parameters.begin.omg" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.parameters.end.omg" }
          },
          "patterns": [
            {
              "name": "variable.parameter.omg",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.parameter.omg",
              "match": ","
            }
          ]
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "\\b(length|chr|ascii|hex|binary|freeze|panic|raise|read_file|file_exists|file_open|file_read|file_write|file_close|call_builtin)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.builtin.omg" }
          }
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.omg" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.omg",
          "match": "\\b(if|elif|else|loop|break|return)\\b"
        },
        {
          "name": "keyword.control.exception.omg",
          "match": "\\b(try|except|facts)\\b"
        },
        {
          "name": "keyword.control.declaration.omg",
          "match": "\\b(alloc|proc|import|as|emit)\\b"
        },
        {
          "name": "keyword.operator.logical.omg",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.omg",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.omg",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.omg",
              "match": "\\\\(n|t|r|0|\"|\\\\)"
            },
            {
              "name": "invalid.illegal.escape.omg",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.binary.omg",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.omg",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.omg",
          "match": ":="
        },
        {
          "name": "keyword.operator.comparison.omg",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitwise.omg",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.omg",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.omg",
          "match": "\\b(args|module_file|current_dir)\\b"
        },
        {
          "name": "variable.other.omg",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
